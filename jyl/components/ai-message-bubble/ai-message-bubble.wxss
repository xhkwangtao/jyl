.ai-message-container {
  display: flex;
  align-items: flex-start;
  justify-content: flex-start;
  gap: 12rpx;
  padding: 12rpx 16rpx;
}

.avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  flex-shrink: 0;
  box-shadow: 4rpx 0 10rpx rgba(0, 0, 0, 0.08);
}

.content-wrapper {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: flex-start;
}

.bubble-container {
  position: relative;
  max-width: 520rpx;
  padding: 12rpx 16rpx;
  background: linear-gradient(
    135deg,
    rgba(255, 255, 255, 0.95) 0%,
    rgba(248, 252, 255, 0.98) 50%,
    rgba(255, 255, 255, 0.95) 100%
  );
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  border-radius: 6rpx 24rpx 24rpx 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05), inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
}

.message-text {
  display: block;
  color: #333333;
  font-size: 28rpx;
  line-height: 1.6;
  letter-spacing: 0.3rpx;
  text-align: justify;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", "PingFang SC", "Microsoft YaHei", sans-serif;
  font-weight: 400;
  white-space: pre-wrap;
  word-wrap: break-word;
  word-break: break-all;
}

.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 2rpx solid #e8e8e8;
}

.toolbar-left {
  display: flex;
  align-items: center;
  gap: 35rpx;
}

.toolbar-button {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: transform 0.1s ease, opacity 0.2s ease;
}

.toolbar-button:active {
  transform: scale(0.9);
  opacity: 0.8;
}

.toolbar-icon {
  width: 40rpx;
  height: 40rpx;
}

.ai-label {
  color: #9a9a9a;
  font-size: 20rpx;
  line-height: 1.2;
}
