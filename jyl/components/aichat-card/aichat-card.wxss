.aichat-card {
  position: relative;
  width: 100%;
  height: 100%;
  background: linear-gradient(to bottom, #DFF0FF, #F4FAFF);
  background: -webkit-linear-gradient(#DFF0FF, #F4FAFF);
  border-radius: 32rpx;
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

.aichat-card:active {
  transform: scale(0.98);
}

.card-content {
  position: relative;
  z-index: 2;
  margin-left: 40%;
  padding-top: 26rpx;
  padding-right: 20rpx;
}

.card-title {
  display: block;
  margin-bottom: 14rpx;
  overflow: hidden;
  color: #000000;
  font-size: 32rpx;
  font-family: 'Alibaba-PuHuiTi-Medium', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-weight: 500;
  line-height: 44rpx;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.card-description {
  display: block;
  color: #000000;
  font-size: 20rpx;
  font-family: 'Asap Condensed', -apple-system, BlinkMacSystemFont, sans-serif;
  font-weight: 400;
  line-height: 28rpx;
  white-space: pre-line;
}

.ai-icon-container {
  position: absolute;
  left: 20rpx;
  top: 50%;
  z-index: 3;
  transform: translateY(-50%);
}

.ai-icon {
  width: 96rpx;
  height: 86rpx;
}
