/* components/universal-navigation/universal-navigation.wxss */

/* 通用导航栏容器 */
.universal-nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  width: 100vw;
  z-index: 9999;
  box-sizing: border-box;
}

/* 状态栏区域 */
.status-bar {
  width: 100vw;
}

/* 导航内容区域 */
.nav-content {
  position: relative;
  width: 100vw;
  box-sizing: border-box;
}

/* 左侧按钮组 */
.nav-left {
  position: absolute;
  display: flex;
  align-items: center; /* 垂直居中 */
  justify-content: center; /* 水平居中 */
  gap: 2.13vw; /* 16rpx ≈ 2.13vw */
  z-index: 2;
  /* top, left, height 通过内联样式设置，使用胶囊按钮的精确位置 */
}

/* 胶囊按钮容器 - 模仿微信胶囊按钮样式 */
.nav-buttons-capsule {
  display: flex;
  align-items: center; /* 垂直居中 */
  height: 100%; /* 高度与胶囊按钮一致 */
  border-radius: 999rpx; /* 使用大圆角，形成胶囊形状 */
  padding: 0 1.07vw; /* 8rpx ≈ 1.07vw - 内边距 */
  min-width: 18vw; /* 确保容器宽度足够容纳两个按钮 */
}

/* 深色主题胶囊 */
.dark-capsule {
  background: rgba(255, 255, 255, 0.85);
  border: 0.13vw solid rgba(0, 0, 0, 0.1); /* 1rpx ≈ 0.13vw */
}

/* 浅色主题胶囊 */
.light-capsule {
  background: rgba(0, 0, 0, 0.15);
  border: 0.27vw solid rgba(255, 255, 255, 0.2); /* 2rpx ≈ 0.27vw */
  backdrop-filter: blur(.0vw); /* 10rpx ≈ 1.33vw */
}

/* 中间标题 - 绝对定位居中 */
.nav-title {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  margin: auto;
  font-size: 4.27vw; /* 32rpx ≈ 4.27vw */
  font-weight: 600;
  text-align: center;
  max-width: 48vw; /* 限制最大宽度，避免与按钮重叠 */
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  z-index: 1; /* 低于按钮的层级 */
}

/* 深色主题标题 */
.dark-title {
  color: #000000;
}

/* 浅色主题标题 */
.light-title {
  color: #ffffff;
  text-shadow: 0 0.27vw 0.53vw rgba(0, 0, 0, 0.3); /* 2rpx 4rpx */
}

/* 右侧按钮区域 */
.nav-right {
  position: absolute;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
  /* top, right, height 通过内联样式设置，使用胶囊按钮的精确位置 */
}

/* 通用按钮样式 */
.nav-button {
  width: 8.53vw; /* 64rpx ≈ 8.53vw - 保持正方形 */
  height: 8.53vw; /* 64rpx ≈ 8.53vw - 保持正方形 */
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  cursor: pointer;
  position: relative;
  flex-shrink: 0; /* 防止按钮被压缩 */
}

.nav-button:active {
  background: rgba(0, 0, 0, 0.1);
}

/* 胶囊按钮样式 */
.capsule-left {
  border-radius: 0;
}

/* 深色主题分割线 */
.dark-capsule .capsule-left {
  border-right: 0.13vw solid rgba(0, 0, 0, 0.1); /* 1rpx ≈ 0.13vw */
}

/* 浅色主题分割线 */
.light-capsule .capsule-left {
  border-right: 0.13vw solid rgba(255, 255, 255, 0.2); /* 1rpx ≈ 0.13vw */
}

.capsule-right {
  border-radius: 0;
}

/* 独立胶囊样式（右侦用户按钮） */
.capsule-style {
  border-radius: 50%; /* 圆形按钮 */
  width: 8.53vw !important; /* 确保宽度 */
  height: 8.53vw !important; /* 确保高度 */
}

/* 深色主题用户按钮 */
.dark-button.capsule-style {
  background: rgba(255, 255, 255, 0.85);
  border: 0.13vw solid rgba(0, 0, 0, 0.1); /* 1rpx ≈ 0.13vw */
}

/* 浅色主题用户按钮 */
.light-button.capsule-style {
  background: rgba(0, 0, 0, 0.15);
  border: 0.27vw solid rgba(255, 255, 255, 0.2); /* 2rpx ≈ 0.27vw */
  backdrop-filter: blur(1.33vw); /* 10rpx ≈ 1.33vw */
}

/* 单按钮样式 - 当只有返回按钮时 */
.single-button {
  border-radius: 50%; /* 圆形按钮 */
  width: 8.53vw !important; /* 确保宽度 */
  height: 8.53vw !important; /* 确保高度 */
}

/* 深色主题单按钮 */
.dark-single {
  background: rgba(255, 255, 255, 0.85);
  border: 0.13vw solid rgba(0, 0, 0, 0.1); /* 1rpx ≈ 0.13vw */
}

/* 浅色主题单按钮 */
.light-single {
  background: rgba(0, 0, 0, 0.15);
  border: 0.27vw solid rgba(255, 255, 255, 0.2); /* 2rpx ≈ 0.27vw */
  backdrop-filter: blur(1.33vw); /* 10rpx ≈ 1.33vw */
}

.capsule-style:active {
  background: rgba(255, 255, 255, 0.7);
}

/* 按钮图标 */
.nav-icon {
  width: 4.8vw; /* 36rpx ≈ 4.8vw */
  height: 4.8vw; /* 36rpx ≈ 4.8vw */
  object-fit: contain; /* 保持图标比例 */
}

/* 深色主题（黑色图标） */
.theme-dark .nav-icon {
  filter: brightness(0); /* 将图标变为黑色 */
  opacity: 0.7;
}

/* 浅色主题（白色图标） */
.theme-light .nav-icon {
  filter: brightness(0) invert(1); /* 将图标变为白色 */
  opacity: 0.9;
  drop-shadow: 0 0.27vw 0.53vw rgba(0, 0, 0, 0.2); /* 2rpx 4rpx */
}

/* 按钮按下状态 - 提供即时视觉反馈 */
.nav-button.pressed {
  transform: scale(0.92);
  transition: transform 0.1s ease-out;
}

/* 胶囊按钮按下状态 */
.nav-buttons-capsule .nav-button.pressed {
  background: rgba(0, 0, 0, 0.08);
}

/* 深色主题按下状态 */
.dark-capsule .nav-button.pressed,
.dark-single.pressed {
  background: rgba(0, 0, 0, 0.1);
}

/* 浅色主题按下状态 */
.light-capsule .nav-button.pressed,
.light-single.pressed {
  background: rgba(255, 255, 255, 0.25);
}

.nav-button:active .nav-icon {
  opacity: 0.9;
}

/* 用户头像特殊处理 */
.user-avatar {
  filter: none !important; /* 用户头像保持原色 */
  border-radius: 50%;
  opacity: 1 !important;
  width: 4.8vw !important; /* 确保尺寸 */
  height: 4.8vw !important; /* 确保尺寸 */
  object-fit: cover; /* 保持头像比例 */
}

/* 普通风格按钮 */
.normal-style {
  background: rgba(255, 255, 255, 0.85);
  border-radius: 50%;
  border: 0.13vw solid rgba(0, 0, 0, 0.1); /* 1rpx ≈ 0.13vw */
  width: 8.53vw !important; /* 确保宽度 */
  height: 8.53vw !important; /* 确保高度 */
}

.normal-style:active {
  background: rgba(255, 255, 255, 0.7);
  transform: scale(0.95);
}