.input-bar-container {
  width: 100%;
  box-sizing: border-box;
  padding-top: 20rpx;
  padding-bottom: 60rpx;
  background: transparent;
  transform: translateZ(0);
  -webkit-backface-visibility: hidden;
  backface-visibility: hidden;
}

.input-bar-wrapper {
  position: relative;
  display: flex;
  align-items: center;
  gap: 16rpx;
  height: 80rpx;
  margin-left: 20rpx;
  margin-right: 20rpx;
  padding: 16rpx 20rpx;
  background: #ffffff;
  border-radius: 60rpx;
  box-shadow: 0 10rpx 30rpx rgba(58, 24, 127, 0.1);
  box-sizing: border-box;
}

.input-bar-wrapper::before {
  content: '';
  position: absolute;
  inset: -2rpx;
  padding: 2rpx;
  background: linear-gradient(to right, #8f41e9, #578aef);
  border-radius: 60rpx;
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  z-index: -1;
}

.icon-button {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 50%;
  transition: all 0.2s ease;
}

.icon {
  width: 48rpx;
  height: 48rpx;
}

.input-core {
  flex: 1;
  height: 100%;
}

.text-input {
  width: 100%;
  height: 100%;
  font-size: 24rpx;
  color: #131313;
}

.text-input[disabled] {
  color: #999999;
  background-color: #f5f5f5;
}

.button-group {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.icon-button:not(.hidden) {
  animation: buttonSlideIn 0.2s ease-out;
}

.send-button.inactive .icon {
  opacity: 0.4;
}

.send-button.active:active {
  background: rgba(54, 255, 134, 0.1);
  transform: scale(0.95);
}

.stop-button {
  background: rgba(255, 71, 87, 0.1);
  border: 2rpx solid rgba(255, 71, 87, 0.2);
}

.stop-button:active {
  background: rgba(255, 71, 87, 0.2);
  transform: scale(0.95);
}

.stop-icon {
  filter: sepia(1) hue-rotate(340deg) saturate(2) brightness(0.9);
}

.hidden {
  width: 0;
  height: 0;
  opacity: 0;
  overflow: hidden;
  margin: 0;
  padding: 0;
  transition: all 0.2s ease;
}

.voice-input-button {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #555555;
}

.voice-input-button-hover {
  background-color: #e0e0e0;
}

.voice-input-button.recording {
  background: #ff4757;
  color: #ffffff;
  animation: recordingPulse 1.5s infinite ease-in-out;
}

.recording-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.recording-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #ffffff;
  animation: recordingDot 1s infinite ease-in-out;
}

.voice-hint {
  display: flex;
  align-items: center;
  justify-content: center;
}

.ai-disclaimer {
  width: 100%;
  padding: 8rpx 0;
  margin-top: 8rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.ai-disclaimer-text {
  font-size: 22rpx;
  line-height: 1.4;
  color: #9a9a9a;
  font-weight: 400;
  letter-spacing: 0.5rpx;
}

@keyframes buttonSlideIn {
  from {
    opacity: 0;
    transform: scale(0.8);
  }

  to {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes recordingPulse {
  0%,
  100% {
    transform: scale(1);
    opacity: 1;
  }

  50% {
    transform: scale(1.05);
    opacity: 0.8;
  }
}

@keyframes recordingDot {
  0%,
  100% {
    opacity: 1;
  }

  50% {
    opacity: 0.3;
  }
}
