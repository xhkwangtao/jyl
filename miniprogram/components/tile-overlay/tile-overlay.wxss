.tile-overlay-container {
  position: relative;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.loading-indicator {
  position: absolute;
  top: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 10rpx 18rpx;
  border-radius: 20rpx;
  background: rgba(19, 28, 36, 0.72);
  color: #fff;
  font-size: 24rpx;
  z-index: 1000;
  pointer-events: none;
}

.loading-text {
  display: block;
}
