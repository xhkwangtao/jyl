.audio-list-overlay {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 1200;
  display: flex;
  justify-content: center;
  align-items: flex-end;
}

.audio-list-mask {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(0, 0, 0, 0.35);
}

.audio-list-drawer {
  position: relative;
  width: 100%;
  max-height: 60vh;
  background: transparent;
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
  box-shadow: 0 -20rpx 40rpx rgba(0, 0, 0, 0.12);
  overflow: hidden;
}

.figma-container {
  width: 100%;
  height: 100%;
  min-height: 100%;
  position: absolute;
  top: 0;
  left: 0;
  overflow: hidden;
  z-index: 0;
}

.background-base {
  width: 100%;
  height: 100%;
  left: 0px;
  top: 0px;
  position: absolute;
  background: white;
  box-shadow: 0px 0px 20px rgba(58, 24, 127, 0.30);
  border-top-left-radius: 16px;
  border-top-right-radius: 16px;
}

.bg-decoration {
  position: absolute;
  border-radius: 9999px;
}

.bg-decoration-1 {
  width: 407.50px;
  height: 188.13px;
  left: -2.14px;
  top: 41.50px;
  transform: rotate(14deg);
  transform-origin: top left;
  background: #EBFBFB;
  box-shadow: 111px 111px 111px rgba(0, 0, 0, 0.1);
  filter: blur(55.50px);
}

.bg-decoration-2 {
  width: 201px;
  height: 73px;
  left: 43px;
  top: -20px;
  background: #FFE9F9;
  box-shadow: 66px 66px 66px rgba(0, 0, 0, 0.1);
  filter: blur(33px);
}

.bg-decoration-3 {
  width: 64.74px;
  height: 163.23px;
  left: 187.94px;
  top: 53.34px;
  transform: rotate(-105deg);
  transform-origin: top left;
  background: #D0E9FF;
  box-shadow: 66px 66px 66px rgba(0, 0, 0, 0.1);
  filter: blur(33px);
}

.bg-decoration-4 {
  width: 139.64px;
  height: 77.86px;
  left: -38.56px;
  top: -46px;
  transform: rotate(14deg);
  transform-origin: top left;
  background: #DDF4E2;
  box-shadow: 66px 66px 66px rgba(0, 0, 0, 0.1);
  filter: blur(33px);
}

.bg-decoration-5 {
  width: 134px;
  height: 73px;
  left: 287px;
  top: -27px;
  background: #F3FFFB;
  box-shadow: 77px 77px 77px rgba(0, 0, 0, 0.1);
  filter: blur(38.50px);
}

.bg-decoration.bottom {
  top: auto;
  bottom: 0;
  opacity: 0.7;
}

.drawer-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 40rpx 20rpx;
  position: relative;
  z-index: 1;
}

.drawer-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #000;
}

.drawer-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: rgba(0, 0, 0, 0.04);
  display: flex;
  align-items: center;
  justify-content: center;
}

.drawer-close:active {
  background: rgba(0, 0, 0, 0.1);
}

.drawer-close-icon {
  font-size: 40rpx;
  line-height: 1;
  color: #666666;
}

.drawer-body {
  max-height: calc(60vh - 120rpx);
  padding: 0 40rpx 40rpx;
  box-sizing: border-box;
  position: relative;
  z-index: 1;
}

.audio-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1px solid rgba(0, 0, 0, 0.05);
}

.audio-item:last-child {
  border-bottom: none;
}

.audio-item-cover {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: #f2f2f2;
  margin-right: 24rpx;
  position: relative;
  overflow: hidden;
}

.cover-img {
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
}

.cover-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(0,0,0,0.06) 0%, rgba(0,0,0,0.18) 100%);
}

.cover-status {
  position: absolute;
  right: 8rpx;
  bottom: 8rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 18rpx;
  background: rgba(255,255,255,0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.15);
}

.cover-status-icon {
  width: 28rpx;
  height: 28rpx;
}

/* 🔊 复用弹窗的播放按钮样式 */
.play-audio-button {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 20rpx;
  height: 20rpx;
  background-color: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  cursor: pointer;
  z-index: 5;
}

.play-audio-button:active {
  background-color: rgba(0, 0, 0, 0.7);
}

.play-icon-triangle {
  width: 0;
  height: 0;
  border-style: solid;
  border-width: 10px 0 10px 20px;
  border-color: transparent transparent transparent white;
  margin-left: 5px;
}

.pause-icon-bars {
  display: flex;
  gap: 4px;
  align-items: center;
  justify-content: center;
}

.pause-icon-bars::before,
.pause-icon-bars::after {
  content: '';
  width: 6px;
  height: 20px;
  background: white;
}

.audio-item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.audio-item-title {
  font-size: 30rpx;
  color: #000;
  font-weight: 700;
}

.audio-item-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #666;
}

.audio-item-status {
  display: flex;
  align-items: center;
}

.status-indicator {
  width: 12rpx;
  height: 12rpx;
  border-radius: 6rpx;
  background: #33c481;
  margin-right: 12rpx;
  animation: statusPulse 1.2s ease-in-out infinite alternate;
}

.status-text {
  font-size: 24rpx;
  color: #33c481;
}

.audio-item.active {
  background: rgba(44, 237, 184, 0.10);
  border-radius: 20rpx;
  padding: 20rpx;
}

.audio-item.active .audio-item-title {
  color: #000;
}

.audio-item.active .audio-item-subtitle {
  color: #2CEDB8;
}

.empty-placeholder {
  padding: 80rpx 0;
  text-align: center;
  color: #a0a0a0;
  font-size: 26rpx;
}

@keyframes statusPulse {
  from {
    transform: scale(0.9);
    opacity: 0.6;
  }
  to {
    transform: scale(1.2);
    opacity: 1;
  }
}
