<view class="badge-grid-container" wx:if="{{displayBadges && displayBadges.length > 0}}">
  <view class="badge-row first-row">
    <view
      class="badge-item single-badge {{displayBadges[0].unlocked ? 'badge-unlocked' : 'badge-locked'}}"
      bind:tap="onBadgeTap"
      data-index="0"
      wx:if="{{displayBadges[0]}}"
    >
      <view class="badge-image-container badge-image-container-big">
        <image class="badge-image-big" src="{{displayBadges[0].image}}" mode="aspectFit" binderror="onImageError" data-index="0"></image>
        <view class="lock-overlay" wx:if="{{!displayBadges[0].unlocked}}">
          <text class="lock-icon">🔒</text>
        </view>
      </view>
      <text class="badge-name">{{displayBadges[0].name}}</text>
      <text class="badge-description" wx:if="{{displayBadges[0].description}}">{{displayBadges[0].description}}</text>
    </view>
  </view>

  <view class="badge-row normal-row">
    <view class="badge-item {{displayBadges[1].unlocked ? 'badge-unlocked' : 'badge-locked'}}" bind:tap="onBadgeTap" data-index="1" wx:if="{{displayBadges[1]}}">
