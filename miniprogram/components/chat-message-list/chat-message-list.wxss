.chat-message-list-container {
  width: 100%;
  background: transparent;
}

.messages-wrapper {
  padding-top: 24rpx;
  padding-bottom: 24rpx;
  box-sizing: border-box;
}

.message-item {
  width: 100%;
}

.message-item-wrapper {
  width: 100%;
}

.loading-indicator {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
}

.loading-dots {
  display: flex;
  gap: 8rpx;
  align-items: center;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #2cedb8;
  animation: bounce 1.4s infinite ease-in-out;
}

.dot-1 {
  animation-delay: -0.32s;
}

.dot-2 {
  animation-delay: -0.16s;
}

.dot-3 {
  animation-delay: 0s;
}

.loading-text {
  font-size: 24rpx;
  line-height: 1.4;
  color: #6b7b8c;
}

.bottom-safe-area {
  width: 100%;
  height: 40rpx;
  background: transparent;
}

@keyframes bounce {
  0%,
  80%,
  100% {
    transform: scale(0.8);
    opacity: 0.5;
  }

  40% {
    transform: scale(1.2);
    opacity: 1;
  }
}
