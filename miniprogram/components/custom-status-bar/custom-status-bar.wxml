<view class="custom-nav-bar" style="padding-top: {{statusBarHeight}}px;">
  <view class="nav-bar-content" style="height: {{navBarHeight}}px;">
    <view class="left-content" bind:tap="onUserAvatarTap">
      <view class="{{avatarShellClassName}}">
        <image class="{{avatarClassName}}" src="{{displayAvatarSrc}}" mode="{{avatarMode}}"></image>
      </view>
      <text class="user-name">{{displayUserName}}</text>
    </view>
  </view>
</view>
