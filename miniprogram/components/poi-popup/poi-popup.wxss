:host {
  display: block;
  width: 100%;
}

.figma-container {
  position: relative;
  margin: 0 0 calc(env(safe-area-inset-bottom) + 20rpx);
  padding: 24rpx 24rpx 28rpx;
  overflow: hidden;
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
}

.background-base {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: #ffffff;
  box-shadow: 0 0 40rpx rgba(58, 24, 127, 0.18);
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
}

.bg-decoration {
  position: absolute;
  border-radius: 999rpx;
  pointer-events: none;
}

.bg-decoration-1 {
  width: 560rpx;
  height: 260rpx;
  left: -20rpx;
  top: 120rpx;
  transform: rotate(14deg);
  background: #ebfbfb;
  filter: blur(56rpx);
}

.bg-decoration-2 {
  width: 280rpx;
  height: 112rpx;
  left: 88rpx;
  top: -32rpx;
  background: #ffe9f9;
  filter: blur(40rpx);
}

.bg-decoration-3 {
  width: 120rpx;
  height: 240rpx;
  left: 360rpx;
  top: 90rpx;
  transform: rotate(-105deg);
  background: #d0e9ff;
  filter: blur(40rpx);
}

.bg-decoration-4 {
  width: 220rpx;
  height: 120rpx;
  left: -60rpx;
  top: -52rpx;
  transform: rotate(14deg);
  background: #ddf4e2;
  filter: blur(40rpx);
}

.bg-decoration-5 {
  width: 220rpx;
  height: 110rpx;
  right: -40rpx;
  top: -30rpx;
  background: #f3fffb;
  filter: blur(42rpx);
}

.poi-header {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.poi-title {
  flex: 1;
  min-width: 0;
  color: #000000;
  font-size: 32rpx;
  font-weight: 500;
  line-height: 1.3;
}

.close-button {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  z-index: 2;
}

.close-button:active {
  background: rgba(0, 0, 0, 0.16);
  transform: scale(0.96);
}

.close-icon {
  color: #666666;
  font-size: 34rpx;
  line-height: 1;
  font-weight: 700;
}

.popup-main {
  position: relative;
  z-index: 1;
  display: flex;
  gap: 24rpx;
  margin-top: 20rpx;
}

.poi-avatar-container {
  position: relative;
  width: 240rpx;
  height: 180rpx;
  border-radius: 32rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.poi-avatar {
  width: 100%;
  height: 100%;
}

.cover-mask {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: linear-gradient(180deg, rgba(21, 31, 44, 0.08) 0%, rgba(21, 31, 44, 0.42) 100%);
}

.play-audio-button {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 72rpx;
  height: 72rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 3;
}

.play-audio-button:active {
  background: rgba(0, 0, 0, 0.7);
}

.play-icon-triangle {
  width: 0;
  height: 0;
  margin-left: 6rpx;
  border-style: solid;
  border-width: 14rpx 0 14rpx 24rpx;
  border-color: transparent transparent transparent #ffffff;
}

.pause-icon-bars {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.pause-icon-bars::before,
.pause-icon-bars::after {
  content: '';
  width: 8rpx;
  height: 24rpx;
  background: #ffffff;
  display: block;
}

.marker-icon-shell {
  position: absolute;
  left: 50%;
  bottom: 46rpx;
  width: 72rpx;
  height: 72rpx;
  transform: translateX(-50%);
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
  z-index: 2;
}

.marker-icon {
  width: 40rpx;
  height: 40rpx;
}

.type-badge {
  position: absolute;
  left: 16rpx;
  bottom: 16rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  z-index: 2;
}

.type-badge-text {
  color: #0f3e49;
  font-size: 20rpx;
  line-height: 1;
  font-weight: 600;
}

.popup-side {
  flex: 1;
  min-width: 0;
}

.data-container {
  display: flex;
  align-items: stretch;
  min-height: 96rpx;
  padding: 18rpx 0;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.36);
  border: 1rpx solid rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(12rpx);
}

.data-section {
  flex: 1;
  min-width: 0;
  padding: 0 18rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.data-section-right {
  align-items: flex-start;
}

.data-value-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.data-number {
  color: #000000;
  font-size: 42rpx;
  line-height: 1;
  font-weight: 700;
}

.data-unit {
  color: #000000;
  font-size: 20rpx;
  line-height: 1.2;
  font-weight: 600;
}

.data-description {
  margin-top: 8rpx;
  color: #000000;
  font-size: 20rpx;
  line-height: 1.2;
}

.data-divider {
  width: 2rpx;
  margin: 8rpx 0;
  background: rgba(15, 62, 73, 0.28);
}

.popup-copy-block {
  margin-top: 16rpx;
}

.chip-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.popup-chip {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(181, 230, 220, 0.96);
  color: #0f3e49;
  font-size: 20rpx;
  line-height: 1;
  font-weight: 600;
}

.popup-stay {
  color: #3f4b53;
  font-size: 22rpx;
  line-height: 1.2;
}

.popup-description {
  display: block;
  margin-top: 12rpx;
  color: #2f2f2f;
  font-size: 24rpx;
  line-height: 1.5;
}

.popup-guide-tip {
  display: block;
  margin-top: 8rpx;
  color: #6a6a6a;
  font-size: 20rpx;
  line-height: 1.5;
}

.buttons-container {
  position: relative;
  z-index: 1;
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.buttons-container.single-button .popup-button {
  width: 100%;
}

.popup-button {
  position: relative;
  flex: 1;
  min-width: 0;
  height: 76rpx;
  border-radius: 999rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.popup-button:active {
  transform: scale(0.98);
}

.popup-button.full-width {
  width: 100%;
}

.popup-button-bg {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: #2cedb8;
}

.popup-button-text {
  position: relative;
  z-index: 1;
  color: #000000;
  font-size: 24rpx;
  line-height: 1;
  font-weight: 700;
  margin-right: 10rpx;
}

.popup-button-arrow {
  position: relative;
  z-index: 1;
  width: 20rpx;
  height: 20rpx;
}
