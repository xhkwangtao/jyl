.ai-message-container {
  display: flex;
  align-items: flex-start;
  justify-content: flex-start;
  gap: 12rpx;
  padding: 12rpx 16rpx;
}

.avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  flex-shrink: 0;
  box-shadow: 4rpx 0 10rpx rgba(0, 0, 0, 0.08);
}

.content-wrapper {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: flex-start;
}

.bubble-container {
  position: relative;
  max-width: 520rpx;
  padding: 12rpx 16rpx;
  background: linear-gradient(
    135deg,
    rgba(255, 255, 255, 0.95) 0%,
    rgba(248, 252, 255, 0.98) 50%,
    rgba(255, 255, 255, 0.95) 100%
  );
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  border-radius: 6rpx 24rpx 24rpx 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05), inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
}

.message-text {
  display: block;
  color: #333333;
  font-size: 28rpx;
  line-height: 1.6;
  letter-spacing: 0.3rpx;
  text-align: justify;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", "PingFang SC", "Microsoft YaHei", sans-serif;
  font-weight: 400;
  white-space: pre-wrap;
  word-wrap: break-word;
  word-break: break-all;
}

.message-rich-text {
  display: block;
  color: #333333;
}

.message-text + .message-text {
  margin-top: 16rpx;
}

.route-card {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.96) 0%, rgba(235, 247, 252, 0.96) 100%);
  border: 1rpx solid rgba(15, 62, 73, 0.08);
  box-shadow: 0 10rpx 28rpx rgba(15, 62, 73, 0.08);
}

.route-card-head {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.route-card-kicker {
  color: #0f7f78;
  font-size: 20rpx;
  font-weight: 700;
}

.route-card-title {
  color: #16222c;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.3;
}

.route-card-description {
  display: block;
  margin-top: 12rpx;
  color: #58636c;
  font-size: 22rpx;
  line-height: 1.6;
}

.route-card-metrics {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 16rpx;
}

.route-card-metric {
  min-width: 0;
  padding: 16rpx 12rpx;
  border-radius: 18rpx;
  background: rgba(15, 62, 73, 0.05);
}

.route-card-metric-value {
  display: block;
  color: #16222c;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.2;
}

.route-card-metric-label {
  display: block;
  margin-top: 8rpx;
  color: #6d7780;
  font-size: 18rpx;
  line-height: 1.4;
}

.route-card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.route-card-tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(15, 62, 73, 0.08);
  color: #0f3e49;
  font-size: 20rpx;
  line-height: 1.2;
}

.route-card-action {
  margin-top: 18rpx;
  height: 60rpx;
  border-radius: 999rpx;
  background: #0f3e49;
  display: flex;
  align-items: center;
  justify-content: center;
}

.route-card-action-text {
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
}

.image-group {
  margin-top: 18rpx;
}

.image-group-title {
  display: block;
  color: #16222c;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.4;
}

.image-group-description {
  display: block;
  margin-top: 8rpx;
  color: #58636c;
  font-size: 21rpx;
  line-height: 1.6;
}

.image-group-scroll {
  margin-top: 14rpx;
  white-space: nowrap;
}

.image-group-track {
  display: flex;
  gap: 14rpx;
}

.image-card {
  width: 220rpx;
  border-radius: 18rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 8rpx 20rpx rgba(15, 62, 73, 0.08);
  border: 1rpx solid rgba(15, 62, 73, 0.06);
}

.image-card-media {
  width: 220rpx;
  height: 160rpx;
  display: block;
}

.image-card-caption {
  display: block;
  padding: 12rpx 14rpx 14rpx;
  color: #33414a;
  font-size: 20rpx;
  line-height: 1.5;
  white-space: normal;
}

.video-card {
  margin-top: 18rpx;
  overflow: hidden;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(15, 62, 73, 0.06);
  box-shadow: 0 8rpx 20rpx rgba(15, 62, 73, 0.08);
}

.video-card-media {
  display: block;
  width: 100%;
  height: 292rpx;
  background: #101820;
}

.video-card-body {
  padding: 14rpx 16rpx 16rpx;
}

.video-card-heading {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.video-card-title {
  min-width: 0;
  flex: 1;
  color: #16222c;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.4;
  word-break: break-all;
}

.video-card-duration {
  flex-shrink: 0;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(15, 62, 73, 0.08);
  color: #0f3e49;
  font-size: 18rpx;
  line-height: 1.4;
}

.video-card-description {
  display: block;
  margin-top: 8rpx;
  color: #58636c;
  font-size: 21rpx;
  line-height: 1.6;
}

.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 2rpx solid #e8e8e8;
}

.toolbar-left {
  display: flex;
  align-items: center;
  gap: 35rpx;
}

.toolbar-button {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: transform 0.1s ease, opacity 0.2s ease;
}

.toolbar-button:active {
  transform: scale(0.9);
  opacity: 0.8;
}

.toolbar-icon {
  width: 40rpx;
  height: 40rpx;
}

.ai-label {
  color: #9a9a9a;
  font-size: 20rpx;
  line-height: 1.2;
}
