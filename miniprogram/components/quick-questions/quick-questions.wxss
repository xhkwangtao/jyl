.quick-questions-container {
  width: 100%;
  background: transparent;
  border-radius: 0;
  box-shadow: none;
  border-bottom: 1rpx solid #f0f0f0;
  overflow: hidden;
  transition: all 0.3s ease;
  --macaron-mint: #b8e6d1;
  --macaron-lavender: #d4c5e8;
  --macaron-peach: #ffd3ba;
  --macaron-pink: #ffd0e1;
  --macaron-lemon: #fff3b8;
  --macaron-sky: #c3e7fd;
  --text-medium: #8e9aaf;
  --text-dark: #6b7b8c;
  --cream: #fffef9;
  --background-pure: #ffffff;
}

.disabled {
  opacity: 0.55;
}

.collapsed-view {
  width: 100%;
  height: 102rpx;
  background: var(--cream);
  border-radius: 36rpx;
  backdrop-filter: blur(20px);
}

.questions-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  height: 90%;
  padding: 12rpx 20rpx;
}

.question-chip {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  height: 44rpx;
  padding: 8rpx 18rpx;
  border-radius: 22rpx;
  border: 1rpx solid #cdcdcd;
  background: transparent;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  backdrop-filter: blur(10px);
}

.question-chip:active {
  transform: translateY(-1rpx) scale(1.02);
  box-shadow: 0 6rpx 16rpx rgba(205, 205, 205, 0.3);
  border-color: #999999;
}

.question-text {
  font-size: 24rpx;
  line-height: 1.2;
  color: var(--text-dark);
  font-weight: 500;
  white-space: nowrap;
}

.chip-important {
  margin-left: 8rpx;
  padding: 2rpx 8rpx;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1.2;
  color: #6b21a8;
  background: rgba(223, 213, 255, 0.6);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 12rpx;
}

.expand-btn {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  padding: 8rpx 18rpx;
  margin-left: auto;
  margin-right: 10rpx;
  transition: transform 0.1s ease, opacity 0.2s ease;
}

.expand-btn:active {
  transform: scale(0.9);
  opacity: 0.8;
}

.expand-icon {
  width: 40rpx;
  height: 40rpx;
  image-rendering: auto;
  image-rendering: -webkit-optimize-contrast;
}

.collapse-btn {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: transform 0.1s ease, opacity 0.2s ease;
}

.collapse-btn:active {
  transform: scale(0.9);
  opacity: 0.8;
}

.collapse-icon {
  width: 40rpx;
  height: 40rpx;
  image-rendering: auto;
  image-rendering: -webkit-optimize-contrast;
}

.expanded-view {
  width: 100%;
  height: 400rpx;
  max-height: 400rpx;
  display: flex;
  flex-direction: column;
  background: var(--cream);
  border-radius: 20rpx;
  border: 1rpx solid rgba(184, 230, 209, 0.3);
  box-shadow: 0 8rpx 32rpx rgba(184, 230, 209, 0.08);
  backdrop-filter: blur(10px);
  overflow: hidden;
  position: relative;
  animation: slideUp 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.expanded-view::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, var(--macaron-mint) 0%, var(--macaron-pink) 20%, var(--macaron-sky) 40%, var(--macaron-lemon) 60%, var(--macaron-lavender) 80%, var(--macaron-peach) 100%);
  border-radius: 20rpx 20rpx 0 0;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 48rpx;
  padding: 20rpx 24rpx 16rpx;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(5px);
  border-bottom: 1rpx solid rgba(240, 240, 240, 0.6);
}

.title {
  font-size: 32rpx;
  line-height: 1.2;
  color: var(--text-dark);
  font-weight: 700;
  text-shadow: 0 1rpx 3rpx rgba(255, 255, 255, 0.8);
}

.categories {
  width: 100%;
  height: 72rpx;
  padding: 8rpx 0;
  background: transparent;
}

.category-list {
  display: flex;
  align-items: center;
  gap: 16rpx;
  height: 100%;
  padding: 0 20rpx;
}

.category-tag {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 40rpx;
  padding: 6rpx 20rpx;
  background: linear-gradient(104.43deg, rgba(237, 242, 255, 0.6) 26.24%, rgba(238, 235, 255, 0.6) 80.64%);
  border-radius: 20rpx;
  border: none;
  color: #333333;
  font-size: 24rpx;
  font-weight: 400;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.category-tag.active {
  transform: scale(1.05);
  background: #6e4bfa;
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(110, 75, 250, 0.3);
  font-weight: 500;
}

.category-tag:active {
  transform: translateY(-1rpx) scale(1.02);
  background: linear-gradient(104.43deg, rgba(237, 242, 255, 0.8) 26.24%, rgba(238, 235, 255, 0.8) 80.64%);
}

.questions-grid {
  height: calc(400rpx - 112rpx);
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  box-sizing: border-box;
  transition: opacity 0.15s ease;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(3px);
  position: relative;
}

.questions-grid::before {
  content: '';
  position: absolute;
  top: 0;
  left: 24rpx;
  right: 24rpx;
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(184, 230, 209, 0.3) 20%, rgba(184, 230, 209, 0.6) 50%, rgba(184, 230, 209, 0.3) 80%, transparent 100%);
}

.questions-grid-inner {
  position: relative;
  display: flex;
  flex-direction: column;
  min-height: 100%;
}

.question-card {
  position: relative;
  display: flex;
  align-items: center;
  height: 72rpx;
  padding: 20rpx 18rpx;
  background: #ffffff;
  border-radius: 12rpx;
  border: none;
  margin-bottom: 12rpx;
  transition: all 0.3s cubic-bezier(0.41, 0.05, 0.1, 1);
  animation: fadeInUp 0.25s ease forwards;
  box-shadow: none;
  font-family: -apple-system, Arial, Helvetica, sans-serif;
  -webkit-font-smoothing: antialiased;
}

.question-card:active {
  transform: scale(0.98);
  background: rgba(78, 110, 242, 0.05);
}

.question-card.hot {
  border: 1rpx solid rgba(78, 110, 242, 0.2);
  box-shadow: 0 2rpx 8rpx rgba(78, 110, 242, 0.08);
}

.question-card.hot::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  width: 4rpx;
  height: 100%;
  background: #4e6ef2;
  border-radius: 12rpx 0 0 12rpx;
}

.question-card-text {
  flex: 1;
  font-size: 26rpx;
  line-height: 1.4;
  color: #333333;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.question-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.question-icon image {
  width: 100%;
  height: 100%;
}

.hot-badge,
.new-badge,
.important-badge {
  margin-left: 8rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  line-height: 1.2;
  text-align: center;
  font-weight: 600;
  color: #ffffff;
  flex-shrink: 0;
}

.hot-badge {
  background: #ff7b54;
}

.new-badge {
  background: #2cedb8;
}

.important-badge {
  background: #6e4bfa;
}

.empty-placeholder {
  display: flex;
  flex: 1;
  min-height: 120rpx;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  color: var(--text-medium);
  text-align: center;
  gap: 8rpx;
}

.empty-placeholder-icon {
  font-size: 36rpx;
  line-height: 1;
}

.empty-placeholder-text {
  font-size: 22rpx;
  line-height: 1.5;
  white-space: pre-line;
}

@keyframes slideUp {
  from {
    transform: translateY(20rpx);
    opacity: 0.8;
  }

  to {
    transform: translateY(0);
    opacity: 1;
  }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}
