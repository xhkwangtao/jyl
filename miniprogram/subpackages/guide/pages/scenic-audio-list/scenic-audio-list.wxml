<view class="scenic-detail-page">
  <view class="background-layer">
    <image class="background-svg" src="/images/ai-chat-bg.svg" mode="aspectFill"></image>
  </view>

  <view class="page-header">
    <universal-navigation
      title="{{pageTitle}}"
      show-back="{{true}}"
      showHomeButton="{{true}}"
      background-color="{{navBackground}}"
      theme="{{navTheme}}"
      showUserAvatar="{{false}}"
      useCapsuleStyle="{{false}}"
      useDefaultBack="{{false}}"
      bind:back="onBackTap"
      bind:home="onHomeTap"
    />
  </view>

  <view class="content-layer">
    <view class="detail-section">
      <view class="bg-container">
        <image class="bg-head" src="/images/poi-detail/head.png" mode="widthFix" />
        <image class="bg-mid" src="/images/poi-detail/mid.png" mode="scaleToFill" />
        <image class="bg-foot" src="/images/poi-detail/bottom.png" mode="widthFix" />
      </view>

      <view class="content-wrapper">
        <view class="section-title">
          <text class="decor-title">景点详解</text>
          <view class="decor-location">
            <image class="location-icon" src="/images/poi-detail/location.svg" mode="widthFix" />
            <text class="decor-location-text">{{locationText}}</text>
          </view>
        </view>

        <view wx:if="{{loading}}" class="state-card">
          <text class="state-text">正在同步地图点位内容...</text>
        </view>

        <view wx:elif="{{errorText}}" class="state-card state-card-error">
          <text class="state-text">{{errorText}}</text>
        </view>

        <view wx:elif="{{emptyText}}" class="state-card">
          <text class="state-text">{{emptyText}}</text>
        </view>

        <block wx:elif="{{currentPoi}}">
          <view class="info-block current-poi-card">
            <image
              class="current-poi-cover"
              src="{{currentPoi.coverImage}}"
              mode="aspectFill"
              data-url="{{currentPoi.coverImage}}"
              bindtap="onPreviewImageTap"
            />
            <view class="current-poi-body">
              <view class="current-poi-header">
                <text class="current-poi-title">{{currentPoi.displayName}}</text>
                <text class="current-poi-type">{{currentPoi.typeLabel}}</text>
              </view>
              <text class="current-poi-subtitle">{{currentPoi.subtitle}}</text>
              <text class="current-poi-desc">{{currentPoi.description}}</text>
              <view class="media-tags" wx:if="{{currentPoi.mediaTags.length}}">
                <text class="media-tag" wx:for="{{currentPoi.mediaTags}}" wx:key="*this">{{item}}</text>
              </view>
            </view>
          </view>

          <view class="info-block gallery-block" wx:if="{{currentPoi.previewImageUrls.length}}">
            <view class="block-title-row">
              <text class="block-title">景点图片</text>
              <text class="block-caption">共 {{currentPoi.previewImageUrls.length}} 张</text>
            </view>
            <scroll-view class="gallery-scroll" scroll-x="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
              <view class="gallery-track">
                <image
                  class="gallery-image"
                  wx:for="{{currentPoi.previewImageUrls}}"
                  wx:key="*this"
                  src="{{item}}"
                  mode="aspectFill"
                  data-url="{{item}}"
                  bindtap="onPreviewImageTap"
                />
              </view>
            </scroll-view>
          </view>

          <view class="info-block video-block" wx:if="{{currentPoi.videoUrl}}">
            <view class="block-title-row">
              <text class="block-title">景点视频</text>
              <text class="block-caption">{{currentPoi.videoUrls.length}} 段</text>
            </view>
            <video
              id="poiVideoPlayer"
              class="poi-video"
              src="{{currentPoi.videoUrl}}"
              poster="{{currentPoi.coverImage}}"
              controls="{{true}}"
              show-center-play-btn="{{true}}"
              show-fullscreen-btn="{{true}}"
              object-fit="cover"
              bindplay="onPoiVideoPlay"
            ></video>
          </view>

          <view class="info-block info-list-block">
            <view class="block-title-row">
              <text class="block-title">景点列表</text>
              <text class="block-caption">来源于地图点位接口</text>
            </view>

            <view class="info-list">
              <view
                class="poi-list-item {{item.selected ? 'selected' : ''}}"
                wx:for="{{poiList}}"
                wx:key="id"
                data-id="{{item.id}}"
                bindtap="onPoiSelect"
              >
                <view
                  class="child-cover"
                  data-id="{{item.id}}"
                  catchtap="onPoiPlay"
                >
                  <image class="child-cover-img" src="{{item.coverImage}}" mode="aspectFill"></image>
                  <view class="child-cover-overlay">
                    <image
                      wx:if="{{item.hasAudio}}"
                      class="child-cover-play"
                      src="{{(item.playing && audioPlaying) ? '/images/poi-detail/pause.svg' : '/images/poi-detail/play.svg'}}"
                      mode="widthFix"
                    />
                    <text wx:else class="child-cover-badge">{{item.hasVideo ? '视频' : '图片'}}</text>
                  </view>
                </view>

                <view class="item-body">
                  <view class="item-head">
                    <text class="item-title">{{item.displayName}}</text>
                    <text class="item-type">{{item.typeLabel}}</text>
                  </view>
                  <text class="item-subtitle">{{item.mediaSummary}}</text>
                  <text class="item-desc">{{item.description}}</text>
                </view>

                <view class="item-side">
                  <text class="item-duration">{{item.audioDurationDisplay}}</text>
                  <text class="item-action">{{item.hasAudio ? ((item.playing && audioPlaying) ? '暂停' : '播放') : '查看'}}</text>
                </view>
              </view>
            </view>
          </view>
        </block>
      </view>
    </view>
  </view>

  <view class="audio-player" wx:if="{{currentPoi}}">
    <image class="player-bg-decor" src="/images/poi-detail/player-bg.svg" mode="scaleToFill" />
    <view class="player-content">
      <view class="player-left">
        <image class="player-cover" src="{{audioCover}}" mode="aspectFill" />
        <view class="player-controls {{!currentPoi.hasAudio ? 'disabled' : ''}}" bindtap="toggleAudioPlay">
          <image
            wx:if="{{!audioPlaying}}"
            class="player-control-icon"
            src="/images/poi-detail/play.svg"
            mode="widthFix"
          />
          <image
            wx:else
            class="player-control-icon"
            src="/images/poi-detail/pause.svg"
            mode="widthFix"
          />
        </view>
      </view>

      <view class="player-right">
        <text class="player-title">{{audioTitle}}</text>
        <text class="player-tip">{{currentPoi.hasAudio ? currentPoi.mediaSummary : '当前景点暂无音频讲解，可查看上方图片或视频内容'}}</text>
        <view class="player-info-row">
          <text class="player-duration">音频时长 {{audioDurationDisplay}}</text>
          <text class="player-current">当前 {{audioCurrentDisplay}}</text>
        </view>
        <view class="progress-wrapper">
          <slider
            class="progress-slider"
            min="0"
            max="100"
            step="1"
            value="{{audioProgressPercent}}"
            block-size="20"
            activeColor="#2cedb8"
            backgroundColor="#e5e5e5"
            disabled="{{!currentPoi.hasAudio}}"
            bindchanging="onSliderChanging"
            bindchange="onSliderChange"
          />
        </view>
      </view>
    </view>
  </view>
</view>
