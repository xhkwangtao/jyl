.scenic-detail-page {
  position: relative;
  min-height: 100vh;
  padding-top: 0;
  overflow: visible;
}

.background-layer {
  position: fixed;
  inset: 0;
  z-index: 0;
}

.background-svg {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  pointer-events: none;
}

.page-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 3;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 32rpx 24rpx 0;
}

.content-layer {
  position: relative;
  z-index: 2;
  box-sizing: border-box;
  padding-top: calc(220rpx + constant(safe-area-inset-top));
  padding-top: calc(220rpx + env(safe-area-inset-top));
  padding-bottom: 380rpx;
}

.detail-section {
  position: relative;
  min-height: 80vh;
  margin: 0 32rpx;
  border-radius: 36rpx;
  box-shadow: 0 32rpx 60rpx rgba(14, 32, 65, 0.12);
}

.bg-container {
  position: absolute;
  inset: 0;
  z-index: 0;
  display: flex;
  flex-direction: column;
  border-radius: 36rpx;
  overflow: hidden;
  pointer-events: none;
}

.bg-head,
.bg-foot {
  width: 100%;
  flex-shrink: 0;
  display: block;
}

.bg-mid {
  flex: 1 1 auto;
  width: 100%;
  height: auto;
  display: block;
}

.content-wrapper {
  position: relative;
  z-index: 1;
  padding: 10rpx 44rpx 200rpx;
}

.section-title {
  display: flex;
  gap: 16rpx;
  margin-top: 26rpx;
}

.decor-title {
  color: #f7f5f3;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
}

.decor-location {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding-left: 48rpx;
}

.location-icon {
  width: 32rpx;
  height: 32rpx;
}

.decor-location-text {
  color: #1f1f1f;
  font-size: 26rpx;
  font-weight: 600;
}

.info-block + .info-block {
  margin-top: 22rpx;
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 18rpx;
}

.audio-group {
  margin-top: 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 18rpx 44rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

.group-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 20rpx;
}

.group-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.group-icon {
  width: 88rpx;
  height: 88rpx;
  overflow: hidden;
  border-radius: 20rpx;
  background: #f4f6fb;
  flex-shrink: 0;
}

.group-icon image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.group-texts {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.group-title {
  color: #111b32;
  font-size: 22rpx;
  font-weight: 700;
}

.group-subtitle {
  color: #5a6475;
  font-size: 20rpx;
}

.group-right {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.group-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
}

.group-count {
  color: #475467;
  font-size: 20rpx;
}

.group-duration {
  color: #8f9ba8;
  font-size: 18rpx;
}

.group-arrow {
  width: 18rpx;
  height: 18rpx;
  box-sizing: border-box;
  flex-shrink: 0;
  border-top: 3rpx solid #475467;
  border-right: 3rpx solid #475467;
  transform: rotate(135deg);
  transform-origin: center;
  transition: transform 0.2s ease;
}

.group-arrow.expanded {
  transform: rotate(-45deg);
}

.group-divider {
  height: 1rpx;
  margin: 0 20rpx;
  background: rgba(16, 24, 40, 0.08);
}

.group-body {
  padding: 0 20rpx 14rpx;
}

.group-child {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(16, 24, 40, 0.06);
}

.group-child:last-child {
  border-bottom: none;
}

.child-left {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  flex: 1 1 auto;
}

.child-cover {
  position: relative;
  width: 96rpx;
  height: 96rpx;
  overflow: hidden;
  border-radius: 16rpx;
  background: #eef2ff;
  flex-shrink: 0;
}

.child-cover-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.child-cover-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.35) 100%);
}

.child-cover-play {
  width: 32rpx;
  height: 32rpx;
}

.child-texts {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.child-title {
  color: #1f2a3f;
  font-size: 22rpx;
  font-weight: 700;
}

.child-desc {
  color: #556277;
  font-size: 18rpx;
}

.child-duration {
  color: #8f9ba8;
  font-size: 18rpx;
  flex-shrink: 0;
}

.group-empty {
  padding: 18rpx 0 6rpx;
  text-align: center;
  color: #8f9ba8;
  font-size: 18rpx;
}

.flat-item-row + .flat-item-row {
  border-top: 1rpx solid rgba(16, 24, 40, 0.08);
}

.flat-duration {
  margin-left: 12rpx;
  color: #8f9ba8;
  font-size: 18rpx;
  flex-shrink: 0;
}

.flat-item {
  align-items: center;
  gap: 12rpx;
}

.list-item {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(16, 24, 40, 0.08);
}

.list-item:last-child {
  border-bottom: none;
}

.item-text {
  width: 80%;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.item-title {
  color: #111b32;
  font-size: 20rpx;
  font-weight: 600;
}

.item-subtitle {
  margin-top: 6rpx;
  color: #556277;
  font-size: 18rpx;
}

.audio-player {
  position: fixed;
  left: 2rpx;
  right: 2rpx;
  bottom: 24rpx;
  z-index: 5;
  width: 100vw;
  height: 280rpx;
}

.player-bg-decor {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.player-content {
  position: relative;
  z-index: 1;
  height: 100%;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
}

.player-left {
  position: relative;
  width: 30%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.player-cover {
  width: 120rpx;
  height: 120rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.8);
  border-radius: 50%;
  box-shadow: 0 12rpx 18rpx rgba(0, 0, 0, 0.12);
}

.player-controls {
  position: absolute;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.55);
}

.player-control-icon {
  width: 36rpx;
  height: 36rpx;
}

.player-right {
  width: 70%;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.player-title {
  color: #1f1f1f;
  font-size: 26rpx;
  font-weight: 600;
}

.player-info-row {
  display: flex;
  justify-content: space-between;
  flex-direction: column;
  color: #4a5568;
  font-size: 22rpx;
}

.player-duration,
.player-current {
  font-size: 22rpx;
}

.progress-wrapper {
  position: relative;
  width: 100%;
  height: 54rpx;
  margin-top: 6rpx;
}
