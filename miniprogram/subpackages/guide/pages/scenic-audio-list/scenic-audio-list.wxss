.scenic-detail-page {
  position: relative;
  min-height: 100vh;
  padding-top: 0;
  overflow: visible;
}

.background-layer {
  position: fixed;
  inset: 0;
  z-index: 0;
}

.background-svg {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  pointer-events: none;
}

.page-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 3;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 32rpx 24rpx 0;
}

.content-layer {
  position: relative;
  z-index: 2;
  box-sizing: border-box;
  padding-top: calc(220rpx + constant(safe-area-inset-top));
  padding-top: calc(220rpx + env(safe-area-inset-top));
  padding-bottom: 380rpx;
}

.detail-section {
  position: relative;
  min-height: 80vh;
  margin: 0 32rpx;
  border-radius: 36rpx;
  box-shadow: 0 32rpx 60rpx rgba(14, 32, 65, 0.12);
}

.bg-container {
  position: absolute;
  inset: 0;
  z-index: 0;
  display: flex;
  flex-direction: column;
  border-radius: 36rpx;
  overflow: hidden;
  pointer-events: none;
}

.bg-head,
.bg-foot {
  width: 100%;
  flex-shrink: 0;
  display: block;
}

.bg-mid {
  flex: 1 1 auto;
  width: 100%;
  height: auto;
  display: block;
}

.content-wrapper {
  position: relative;
  z-index: 1;
  padding: 10rpx 44rpx 200rpx;
}

.section-title {
  display: flex;
  gap: 16rpx;
  margin-top: 26rpx;
}

.decor-title {
  color: #f7f5f3;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
}

.decor-location {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding-left: 48rpx;
}

.location-icon {
  width: 32rpx;
  height: 32rpx;
}

.decor-location-text {
  color: #1f1f1f;
  font-size: 26rpx;
  font-weight: 600;
}

.state-card,
.current-poi-card,
.gallery-block,
.video-block,
.info-list-block {
  margin-top: 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 18rpx 44rpx rgba(0, 0, 0, 0.08);
}

.state-card {
  padding: 36rpx 28rpx;
}

.state-card-error {
  background: rgba(255, 244, 244, 0.98);
}

.state-text {
  color: #556277;
  font-size: 24rpx;
  line-height: 1.7;
}

.current-poi-card {
  overflow: hidden;
}

.current-poi-cover {
  width: 100%;
  height: 320rpx;
  display: block;
  background: #eef2ff;
}

.current-poi-body {
  padding: 24rpx 24rpx 28rpx;
}

.current-poi-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.current-poi-title {
  flex: 1 1 auto;
  color: #111b32;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.4;
}

.current-poi-type {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(36, 95, 109, 0.12);
  color: #245f6d;
  font-size: 20rpx;
  font-weight: 600;
}

.current-poi-subtitle {
  display: block;
  margin-top: 12rpx;
  color: #5a6475;
  font-size: 22rpx;
}

.current-poi-desc {
  display: block;
  margin-top: 14rpx;
  color: #334155;
  font-size: 22rpx;
  line-height: 1.8;
}

.media-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.media-tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #eff6ff;
  color: #265e92;
  font-size: 20rpx;
}

.block-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 22rpx 24rpx 0;
}

.block-title {
  color: #111b32;
  font-size: 26rpx;
  font-weight: 700;
}

.block-caption {
  color: #8f9ba8;
  font-size: 20rpx;
}

.gallery-scroll {
  width: 100%;
  white-space: nowrap;
  padding: 20rpx 0 24rpx;
}

.gallery-track {
  display: flex;
  gap: 18rpx;
  padding: 0 24rpx;
}

.gallery-image {
  width: 232rpx;
  height: 168rpx;
  flex-shrink: 0;
  border-radius: 20rpx;
  background: #eef2ff;
}

.video-block {
  padding-bottom: 24rpx;
}

.poi-video {
  width: calc(100% - 48rpx);
  height: 360rpx;
  margin: 20rpx 24rpx 0;
  border-radius: 20rpx;
  overflow: hidden;
  background: #000;
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 18rpx;
  padding: 0 24rpx 24rpx;
}

.poi-list-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(16, 24, 40, 0.08);
  background: rgba(255, 255, 255, 0.88);
}

.poi-list-item.selected {
  border-color: rgba(44, 237, 184, 0.55);
  background: linear-gradient(180deg, rgba(243, 255, 252, 0.98) 0%, rgba(255, 255, 255, 0.98) 100%);
  box-shadow: 0 12rpx 28rpx rgba(44, 237, 184, 0.12);
}

.child-cover {
  position: relative;
  width: 116rpx;
  height: 116rpx;
  overflow: hidden;
  border-radius: 18rpx;
  background: #eef2ff;
  flex-shrink: 0;
}

.child-cover-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.child-cover-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.02) 0%, rgba(0, 0, 0, 0.34) 100%);
}

.child-cover-play {
  width: 36rpx;
  height: 36rpx;
}

.child-cover-badge {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  color: #1f2a3f;
  font-size: 18rpx;
  font-weight: 600;
}

.item-body {
  flex: 1 1 auto;
  min-width: 0;
}

.item-head {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.item-title {
  flex: 1 1 auto;
  color: #111b32;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.45;
}

.item-type {
  flex-shrink: 0;
  color: #245f6d;
  font-size: 20rpx;
  font-weight: 600;
}

.item-subtitle {
  display: block;
  margin-top: 10rpx;
  color: #556277;
  font-size: 20rpx;
}

.item-desc {
  display: block;
  margin-top: 10rpx;
  color: #334155;
  font-size: 20rpx;
  line-height: 1.7;
}

.item-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
  flex-shrink: 0;
}

.item-duration {
  color: #8f9ba8;
  font-size: 18rpx;
}

.item-action {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(36, 95, 109, 0.08);
  color: #245f6d;
  font-size: 18rpx;
  font-weight: 600;
}

.audio-player {
  position: fixed;
  left: 2rpx;
  right: 2rpx;
  bottom: 24rpx;
  z-index: 5;
  width: 100vw;
  height: 280rpx;
}

.player-bg-decor {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.player-content {
  position: relative;
  z-index: 1;
  height: 100%;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
}

.player-left {
  position: relative;
  width: 30%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.player-cover {
  width: 120rpx;
  height: 120rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.8);
  border-radius: 50%;
  box-shadow: 0 12rpx 18rpx rgba(0, 0, 0, 0.12);
}

.player-controls {
  position: absolute;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.55);
}

.player-controls.disabled {
  opacity: 0.45;
}

.player-control-icon {
  width: 36rpx;
  height: 36rpx;
}

.player-right {
  width: 70%;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.player-title {
  color: #1f1f1f;
  font-size: 26rpx;
  font-weight: 600;
}

.player-tip {
  color: #5f6b7b;
  font-size: 20rpx;
  line-height: 1.5;
}

.player-info-row {
  display: flex;
  justify-content: space-between;
  flex-direction: column;
  color: #4a5568;
  font-size: 22rpx;
}

.player-duration,
.player-current {
  font-size: 22rpx;
}

.progress-wrapper {
  position: relative;
  width: 100%;
  height: 54rpx;
  margin-top: 6rpx;
}
