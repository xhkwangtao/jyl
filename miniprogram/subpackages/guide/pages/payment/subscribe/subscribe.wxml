<universal-navigation title="购买研学道具" theme="light" backgroundColor="rgba(0, 0, 0, 0.3)" showHomeButton="{{true}}" showUserAvatar="{{false}}" useCapsuleStyle="{{true}}" useDefaultBack="{{true}}" bind:home="onGoHome" />

<view class="subscribe-page">
  <view class="background-gradient"></view>
  <view class="background-overlay"></view>

  <view class="decoration-elements">
    <view class="decoration circle-1"></view>
    <view class="decoration circle-2"></view>
    <image class="decoration square-1" src="/images/badges/arc-emerald.svg" mode="aspectFit"></image>
    <image class="decoration square-2" src="/images/badges/long.svg" mode="aspectFit"></image>
    <image class="decoration triangle-1" src="/images/badges/arc-orange-yellow.svg" mode="aspectFit"></image>
    <view class="decoration triangle-2"></view>
  </view>

  <view class="title-section">
    <text class="main-title">购买研学道具</text>
    <text class="subtitle">当前提供统一研学道具套装</text>
    <text class="subtitle">支付完成后请前往游客中心领取</text>
  </view>

  <view class="ai-character-section">
    <view class="ai-character-container">
      <image class="ai-character-image" src="{{heroImageSrc}}" mode="aspectFit" binderror="onHeroImageError"></image>
      <view class="ai-face">
        <image class="ai-icon" src="/images/icons/question-start.svg" mode="aspectFit"></image>
      </view>
    </view>

    <view class="feature-tags">
      <view class="feature-tag tag-1">研学手册</view>
      <view class="feature-tag tag-2">任务卡片</view>
      <view class="feature-tag tag-3">集章打卡</view>
      <view class="feature-tag tag-5">游客中心领取</view>
    </view>
  </view>

  <view class="purchase-card">
    <view class="sale-badge">统一套装</view>
    <view class="card-content">
      <text class="promotion-title">研学道具统一套装</text>
      <text class="promotion-subtitle">支付完成后凭订单前往游客中心领取</text>
      <view class="price-section">
        <text class="price-symbol">¥</text>
        <text class="price-value">{{displayAmount}}</text>
        <view class="original-price-section">
          <text class="original-price">¥{{displayOriginalPrice}}</text>
        </view>
      </view>
    </view>
  </view>

  <button class="purchase-button" loading="{{loading}}" disabled="{{loading}}" bindtap="handlePay">确认购买</button>
  <view class="pickup-notice">购买成功后请去游客中心索取研学道具</view>

  <view class="agreement-section">
    <view class="agreement-checkbox-hitbox" bindtap="toggleAgreement">
      <view class="agreement-checkbox">
        <view class="checkbox {{agreed ? 'checked' : ''}}"></view>
      </view>
    </view>
    <text class="agreement-text">
      已阅读并同意
      <text class="agreement-link" bindtap="showServiceAgreement">《服务协议》</text>
      和
      <text class="agreement-link" bindtap="showPrivacyPolicy">《隐私政策》</text>
    </text>
  </view>

  <view class="home-indicator"></view>

  <view wx:if="{{paymentError}}" class="payment-error">{{paymentError}}</view>
</view>
