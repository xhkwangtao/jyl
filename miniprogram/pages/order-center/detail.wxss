.order-detail-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
}

.background-layer {
  position: fixed;
  inset: 0;
  z-index: 0;
}

.background-svg {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  pointer-events: none;
}

.page-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 4;
  padding: 32rpx 24rpx 0;
}

.content-layer {
  position: relative;
  z-index: 2;
  box-sizing: border-box;
  padding: calc(204rpx + constant(safe-area-inset-top)) 24rpx calc(72rpx + constant(safe-area-inset-bottom));
  padding: calc(204rpx + env(safe-area-inset-top)) 24rpx calc(72rpx + env(safe-area-inset-bottom));
}

.state-card,
.detail-card {
  position: relative;
  overflow: hidden;
  border-radius: 32rpx;
  border: 1px solid rgba(36, 72, 92, 0.1);
  background: rgba(255, 251, 246, 0.95);
  box-shadow: 0 18rpx 44rpx rgba(31, 58, 74, 0.1);
}

.state-card::before,
.detail-card::before {
  content: '';
  position: absolute;
  inset: 0;
  pointer-events: none;
  background:
    radial-gradient(circle at top right, rgba(45, 123, 122, 0.1), transparent 28%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.32), transparent 34%);
}

.state-card {
  padding: 56rpx 32rpx 44rpx;
  text-align: center;
}

.state-title,
.state-desc {
  position: relative;
  z-index: 1;
  display: block;
}

.state-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2d35;
}

.state-desc {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6f8d93;
}

.state-action {
  position: relative;
  z-index: 1;
  width: 280rpx;
  min-height: 82rpx;
  margin: 30rpx auto 0;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #2f807d 0%, #245f6d 100%);
  box-shadow: 0 14rpx 26rpx rgba(36, 95, 109, 0.14);
}

.state-action-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #ffffff;
}

.detail-card {
  padding: 28rpx;
}

.section,
.detail-actions {
  position: relative;
  z-index: 1;
}

.section + .section {
  margin-top: 26rpx;
  padding-top: 24rpx;
  border-top: 1px solid rgba(36, 72, 92, 0.08);
}

.section-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.section-title {
  flex: 1;
  min-width: 0;
  font-size: 34rpx;
  line-height: 1.34;
  font-weight: 700;
  color: #1f2d35;
}

.section-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #6f8d93;
}

.order-status {
  flex-shrink: 0;
  font-size: 24rpx;
  font-weight: 700;
}

.order-status-pending {
  color: #d97706;
}

.order-status-paid {
  color: #15803d;
}

.order-status-cancelled {
  color: #64748b;
}

.order-status-refunded {
  color: #0f766e;
}

.copy-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 56rpx;
  margin-top: 18rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: rgba(36, 95, 109, 0.08);
}

.copy-action-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #245f6d;
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.info-row + .info-row {
  margin-top: 14rpx;
}

.info-label {
  font-size: 22rpx;
  color: #7a8d92;
}

.info-value {
  flex: 1;
  min-width: 0;
  text-align: right;
  font-size: 24rpx;
  color: #1f2d35;
}

.info-value-strong {
  font-weight: 700;
}

.info-value-highlight {
  color: #245f6d;
}

.section-heading {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2d35;
}

.item-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  padding: 18rpx 0;
}

.item-row + .item-row {
  border-top: 1px dashed rgba(36, 72, 92, 0.08);
}

.item-title,
.item-meta {
  display: block;
}

.item-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #1f2d35;
}

.item-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #7a8d92;
}

.item-price {
  flex-shrink: 0;
  font-size: 24rpx;
  font-weight: 700;
  color: #1f2d35;
}

.transaction-card {
  margin-top: 18rpx;
  padding: 20rpx 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.76);
  border: 1px solid rgba(36, 72, 92, 0.08);
}

.transaction-state,
.transaction-line {
  display: block;
}

.transaction-state {
  font-size: 24rpx;
  font-weight: 700;
  color: #245f6d;
}

.transaction-line {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #5c6d74;
}

.detail-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 28rpx;
}

.detail-action {
  flex: 1;
  min-height: 82rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.detail-action-primary {
  background: linear-gradient(180deg, #2f807d 0%, #245f6d 100%);
  box-shadow: 0 14rpx 26rpx rgba(36, 95, 109, 0.14);
}

.detail-action-secondary {
  background: rgba(255, 255, 255, 0.92);
  border: 1px solid rgba(36, 95, 109, 0.12);
}

.detail-action-text {
  font-size: 24rpx;
  font-weight: 700;
}

.detail-action-text-primary {
  color: #ffffff;
}

.detail-action-text-secondary {
  color: #245f6d;
}
