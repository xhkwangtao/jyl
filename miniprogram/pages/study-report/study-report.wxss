.study-report-page {
  min-height: 100vh;
  background: #e8edf3;
}

.page-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 10;
}

.content-layer {
  padding: calc(170rpx + constant(safe-area-inset-top)) 24rpx calc(80rpx + constant(safe-area-inset-bottom));
  padding: calc(170rpx + env(safe-area-inset-top)) 24rpx calc(80rpx + env(safe-area-inset-bottom));
}

.preview-shell {
  overflow: hidden;
  border-radius: 0;
  background: #ffffff;
  box-shadow: 0 18rpx 60rpx rgba(15, 23, 42, 0.18);
}

.preview-image {
  display: block;
  width: 100%;
}

.preview-loading,
.preview-error {
  min-height: 996rpx;
  padding: 80rpx 64rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  background: #ffffff;
  box-sizing: border-box;
}

.preview-loading-title,
.preview-error-text {
  font-size: 28rpx;
  line-height: 1.5;
  color: #1f2937;
}

.preview-loading-desc {
  margin-top: 18rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #6b7280;
}

.bottom-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 36rpx;
}

.bottom-action {
  flex: 1;
  min-height: 84rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid #d8d8d8;
  background: #ffffff;
}

.bottom-action-primary {
  background: #2f2f2f;
  border-color: #2f2f2f;
}

.bottom-action-secondary {
  background: #ffffff;
}

.bottom-action-text {
  font-size: 28rpx;
  font-weight: 500;
}

.bottom-action-text-primary {
  color: #ffffff;
}

.bottom-action-text-secondary {
  color: #333333;
}

.report-preview-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 1192px;
  height: 1680px;
  opacity: 0;
  pointer-events: none;
}
