.study-report-page {
  position: relative;
  min-height: 100vh;
  overflow-x: hidden;
}

.background-layer {
  position: fixed;
  inset: 0;
  z-index: 0;
}

.background-svg {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  pointer-events: none;
}

.page-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 5;
}

.content-layer {
  position: relative;
  z-index: 2;
  padding: calc(212rpx + constant(safe-area-inset-top)) 32rpx calc(96rpx + constant(safe-area-inset-bottom));
  padding: calc(212rpx + env(safe-area-inset-top)) 32rpx calc(96rpx + env(safe-area-inset-bottom));
}

.hero-card,
.summary-card,
.theme-summary-card,
.secret-icon-card {
  position: relative;
  overflow: hidden;
  border-radius: 32rpx;
  border: 1px solid rgba(36, 72, 92, 0.1);
  box-shadow: 0 18rpx 44rpx rgba(31, 58, 74, 0.1);
}

.hero-card::before,
.summary-card::before,
.secret-icon-card::before {
  content: '';
  position: absolute;
  inset: 0;
  pointer-events: none;
  background:
    radial-gradient(circle at top right, rgba(45, 123, 122, 0.1), transparent 30%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.32), transparent 38%);
}

.hero-card {
  padding: 30rpx;
  background:
    radial-gradient(circle at top right, rgba(47, 128, 125, 0.08), transparent 34%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.68) 0%, rgba(255, 250, 243, 0.94) 100%);
}

.report-chip,
.hero-kicker,
.hero-title,
.hero-desc,
.stats-grid,
.summary-list,
.section-head,
.secret-wall,
.bottom-actions {
  position: relative;
  z-index: 1;
}

.report-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(44, 237, 184, 0.2);
}

.report-chip-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #1f6a67;
}

.hero-kicker {
  display: block;
  margin-top: 18rpx;
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: #6f8d93;
}

.hero-title {
  display: block;
  margin-top: 12rpx;
  font-size: 42rpx;
  line-height: 1.24;
  font-weight: 700;
  color: #1f2d35;
}

.hero-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #5c6d74;
}

.stats-grid,
.bottom-actions {
  display: flex;
  gap: 14rpx;
}

.stats-grid {
  margin-top: 24rpx;
}

.stat-card {
  flex: 1;
  min-width: 0;
  padding: 20rpx 18rpx 22rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fdfcf9 0%, #eef5f3 100%);
  border: 1px solid rgba(45, 123, 122, 0.08);
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #7a8d92;
}

.stat-value {
  display: block;
  margin-top: 10rpx;
  font-size: 32rpx;
  line-height: 1;
  font-weight: 700;
  color: #1f2d35;
}

.summary-card {
  margin-top: 24rpx;
  padding: 28rpx;
  background: rgba(255, 251, 246, 0.95);
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 28rpx;
  padding: 0 6rpx;
}

.section-head-static {
  margin-top: 0;
  padding: 0;
}

.section-title {
  display: block;
  font-size: 32rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #1f2d35;
}

.section-caption,
.section-right {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #6f8d93;
}

.section-right {
  margin-top: 0;
  flex-shrink: 0;
}

.summary-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 22rpx;
}

.summary-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.summary-dot {
  width: 18rpx;
  height: 18rpx;
  margin-top: 8rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #2f807d 0%, #245f6d 100%);
  flex-shrink: 0;
}

.summary-text {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  line-height: 1.7;
  color: #5c6d74;
}

.theme-summary-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 20rpx;
}

.theme-summary-card {
  padding: 22rpx 20rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.92) 0%, rgba(245, 248, 247, 0.96) 100%);
}

.theme-summary-name {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #245f6d;
}

.theme-summary-value {
  display: block;
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2d35;
}

.secret-wall {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 18rpx 14rpx;
  margin-top: 20rpx;
}

.secret-icon-card {
  padding: 22rpx 12rpx 18rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.95) 0%, rgba(241, 244, 245, 0.98) 100%);
}

.secret-icon-shell {
  height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.secret-icon-image {
  width: 86rpx;
  height: 86rpx;
}

.secret-icon-name {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #1f2d35;
  text-align: center;
}

.secret-icon-caption {
  display: block;
  margin-top: 8rpx;
  font-size: 18rpx;
  line-height: 1.4;
  color: #7f8c96;
  text-align: center;
}

.bottom-actions {
  margin-top: 30rpx;
}

.bottom-action {
  flex: 1;
  min-height: 82rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.bottom-action-primary {
  background: linear-gradient(180deg, #2f807d 0%, #245f6d 100%);
  box-shadow: 0 14rpx 26rpx rgba(36, 95, 109, 0.14);
}

.bottom-action-secondary {
  background: rgba(255, 255, 255, 0.92);
  border: 1px solid rgba(36, 95, 109, 0.12);
}

.bottom-action-text {
  font-size: 24rpx;
  font-weight: 700;
}

.bottom-action-text-primary {
  color: #ffffff;
}

.bottom-action-text-secondary {
  color: #245f6d;
}

@media (max-width: 375px) {
  .secret-wall {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .content-layer {
    padding-left: 24rpx;
    padding-right: 24rpx;
  }

  .hero-title {
    font-size: 38rpx;
  }
}
