<page-meta page-style="{{pageStyle}}"></page-meta>

<view class="study-report-page" style="{{navBarHeightStyle}}">
  <view class="page-header">
    <universal-navigation
      title="研学报告"
      show-back="{{true}}"
      showHomeButton="{{true}}"
      background-color="rgba(232, 237, 243, 0.92)"
      title-color="#2c2823"
      showUserAvatar="{{false}}"
      useCapsuleStyle="{{false}}"
      useDefaultBack="{{false}}"
      bind:back="onBackTap"
      bind:home="onHomeTap"
    />
  </view>

  <view class="content-layer" wx:if="{{pageReady}}">
    <view class="preview-shell">
      <image
        wx:if="{{posterPreviewPath}}"
        class="preview-image"
        src="{{posterPreviewPath}}"
        mode="widthFix"
        show-menu-by-longpress="{{true}}"
      />

      <view class="preview-loading" wx:elif="{{posterGenerating}}">
        <text class="preview-loading-title">正在生成研学报告预览</text>
        <text class="preview-loading-desc">预览和保存图片会统一使用 print.html 版式</text>
      </view>

      <view class="preview-error" wx:else>
        <text class="preview-error-text">{{posterErrorText || '研学报告预览生成失败'}}</text>
      </view>
    </view>

    <view class="bottom-actions">
      <view class="bottom-action bottom-action-primary" bindtap="onOpenMyPage">
        <text class="bottom-action-text bottom-action-text-primary">返回我的档案</text>
      </view>
      <view class="bottom-action bottom-action-secondary" bindtap="onOpenCollectionPage">
        <text class="bottom-action-text bottom-action-text-secondary">查看收集记录</text>
      </view>
    </view>

    <canvas
      id="study-report-preview-canvas"
      type="2d"
      class="report-preview-canvas"
      style="width: 1192px; height: 1680px;"
    />
  </view>
</view>
