}

.page-burst-effects {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 5;
}

.page-burst {
  position: absolute;
  width: 100rpx;
  height: 90rpx;
  opacity: 0;
  animation-duration: 3s;
  animation-timing-function: cubic-bezier(0.25, 0.46, 0.45, 0.94);
  animation-fill-mode: forwards;
  animation-delay: 0.8s;
}

.arc-image {
  width: 100%;
  height: 100%;
}

.page-burst-1 .arc-image {
  transform: rotate(0deg);
}

.page-burst-2 .arc-image {
  transform: rotate(30deg);
}

.page-burst-3 .arc-image {
  transform: rotate(-20deg);
}

.page-burst-4 .arc-image {
  transform: rotate(45deg);
}

.page-burst-5 .arc-image {
  transform: rotate(-45deg);
}

.page-burst-6 .arc-image {
  transform: rotate(60deg);
}

.page-burst-7 .arc-image {
  transform: rotate(-30deg);
}

.page-burst-8 .arc-image {
  transform: rotate(90deg);
}

.page-burst-9 .arc-image {
  transform: rotate(-60deg);
}

.page-burst-10 .arc-image {
  transform: rotate(120deg);
}

.page-burst-11 .arc-image {
  transform: rotate(-90deg);
}

.page-burst-12 .arc-image {
  transform: rotate(150deg);
}

.page-burst-1,
.page-burst-5,
.page-burst-9 {
  animation-delay: 0.8s;
}

.page-burst-2,
.page-burst-6,
.page-burst-10 {
  animation-delay: 0.9s;
}

.page-burst-3,
.page-burst-7,
.page-burst-11 {
