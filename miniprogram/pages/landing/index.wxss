.badge-reward-page {
  width: 100%;
  min-height: 100vh;
  background: linear-gradient(180deg, #ffffff 53%, #ffffff 100%);
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
}

.background-decorations {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 1;
}

.ellipse {
  position: absolute;
  border-radius: 50%;
}

.ellipse-1 {
  width: 600rpx;
  height: 700rpx;
  top: -200rpx;
  left: -100rpx;
  background: radial-gradient(ellipse at center, #c8f7f7 0%, #ebfbfb 25%, rgba(200, 245, 245, 0.7) 50%, transparent 75%);
  filter: blur(50rpx);
  transform: rotate(25deg);
  opacity: 1;
  animation: ellipse-float-1 18s ease-in-out infinite;
}

.ellipse-2 {
  width: 350rpx;
  height: 280rpx;
  top: 30rpx;
  left: 80rpx;
  background: radial-gradient(ellipse at center, #ffd6f3 0%, #ffeaf9 30%, rgba(255, 200, 235, 0.6) 60%, transparent 80%);
  filter: blur(30rpx);
  opacity: 1;
  mix-blend-mode: normal;
  animation: ellipse-float-2 15s ease-in-out infinite;
}

.ellipse-3 {
  width: 320rpx;
  height: 340rpx;
  top: 80rpx;
  right: 30rpx;
  background: radial-gradient(ellipse at center, #a8d8ff 0%, #d0e9ff 25%, rgba(180, 220, 255, 0.7) 60%, transparent 80%);
  filter: blur(35rpx);
  transform: rotate(-82deg);
  opacity: 1;
  animation: ellipse-float-3 20s ease-in-out infinite;
}

.ellipse-4 {
  width: 240rpx;
  height: 300rpx;
  bottom: 180rpx;
  left: 30rpx;
  background: radial-gradient(ellipse at center, #c5edcc 0%, #ddf4e2 25%, rgba(200, 240, 210, 0.7) 60%, transparent 80%);
  filter: blur(35rpx);
  transform: rotate(25deg);
  opacity: 1;
  animation: ellipse-float-4 17s ease-in-out infinite;
}

.ellipse-5 {
  width: 280rpx;
  height: 280rpx;
  bottom: 280rpx;
  right: 60rpx;
  background: radial-gradient(ellipse at center, #e0fff8 0%, #f3fffb 25%, rgba(230, 255, 250, 0.7) 60%, transparent 80%);
  filter: blur(40rpx);
  opacity: 1;
  animation: ellipse-float-5 16s ease-in-out infinite;
}

.map-decoration {
  position: absolute;
  top: 40%;
  left: 50%;
  transform: translate(-50%, -50%) rotate(-15deg);
  font-size: 300rpx;
  font-weight: 900;
  color: rgba(255, 215, 0, 0.15);
  filter: blur(3rpx);
  letter-spacing: 80rpx;
  opacity: 0.6;
  animation: map-float 20s ease-in-out infinite;
  z-index: 0;
}

@keyframes map-float {
  0%,
  100% {
    transform: translate(-50%, -50%) rotate(-15deg) scale(1);
  }

  50% {
    transform: translate(-50%, -50%) rotate(-15deg) scale(1.1);
  }
}

@keyframes ellipse-float-1 {
  0%,
  100% {
    transform: rotate(25deg) translate(0, 0);
  }

  50% {
    transform: rotate(25deg) translate(20rpx, 30rpx);
  }
}

@keyframes ellipse-float-2 {
  0%,
  100% {
    transform: translate(0, 0);
  }

  50% {
    transform: translate(-15rpx, 20rpx);
  }
}

@keyframes ellipse-float-3 {
  0%,
  100% {
    transform: rotate(-82deg) translate(0, 0);
  }

  50% {
    transform: rotate(-82deg) translate(25rpx, -15rpx);
  }
}

@keyframes ellipse-float-4 {
  0%,
  100% {
    transform: rotate(25deg) translate(0, 0);
  }

  50% {
    transform: rotate(25deg) translate(-20rpx, 25rpx);
  }
}

@keyframes ellipse-float-5 {
  0%,
  100% {
    transform: translate(0, 0);
  }

  50% {
    transform: translate(15rpx, -20rpx);
  }
}

.content-container {
  padding-top: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-left: 40rpx;
  padding-right: 40rpx;
  position: relative;
  z-index: 10;
}

.badge-title {
  font-size: 50rpx;
  font-weight: bold;
  color: #212121;
  text-align: center;
  margin-top: 36rpx;
  margin-bottom: 40rpx;
  font-family: 'Alibaba PuHuiTi Bold', 'Alibaba PuHuiTi', 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
}

.success-text {
  font-size: 24rpx;
  color: #000000;
  text-align: left;
  width: 532rpx;
  line-height: 40rpx;
  margin-bottom: 60rpx;
  font-family: 'Alibaba PuHuiTi', 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
}

.success-text .highlight {
  color: #000000;
  font-weight: bold;
  font-size: 44rpx;
  letter-spacing: -1.32rpx;
  font-family: 'DIN Bold', 'Helvetica Neue', Arial, sans-serif;
  vertical-align: baseline;
  margin: 0 4rpx;
}

.badge-container {
  width: 400rpx;
  height: 400rpx;
  position: relative;
  margin-bottom: 20rpx;
}

.badge-svg {
  width: 60vw;
  height: 60vw;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 10;
  animation: badge-entrance 0.6s ease-out;
}

@keyframes badge-entrance {
  0% {
    transform: translate(-50%, -50%) scale(0) rotate(-180deg);
    opacity: 0;
  }

  50% {
    transform: translate(-50%, -50%) scale(1.1) rotate(-90deg);
  }

  100% {
    transform: translate(-50%, -50%) scale(1) rotate(0deg);
    opacity: 1;
  }
}

@keyframes badge-entrance-double-rotation {
  0% {
    transform: translate(-50%, -50%) scale(0) rotate(-180deg);
    opacity: 0;
  }

  25% {
    transform: translate(-50%, -50%) scale(0.8) rotate(-90deg);
  }

  50% {
    transform: translate(-50%, -50%) scale(1.1) rotate(0deg);
  }

  75% {
    transform: translate(-50%, -50%) scale(1.05) rotate(90deg);
  }

  100% {
    transform: translate(-50%, -50%) scale(1) rotate(180deg);
    opacity: 1;
  }
}

.badge-svg.entrance-fast {
  animation: badge-entrance 0.3s ease-out !important;
}

.badge-svg.entrance-slow {
  animation: badge-entrance 1.2s ease-out !important;
}

.badge-svg.entrance-very-slow {
  animation: badge-entrance 2.5s ease-out !important;
}

.badge-svg.entrance-ultra-slow {
  animation: badge-entrance 4s ease-out !important;
}

.badge-svg.entrance-double-rotation {
  animation: badge-entrance-double-rotation 4s ease-out !important;
}

.badge-svg.no-entrance {
  animation: none !important;
  opacity: 1;
}

.explosion-effects {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.glow-effect {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(255, 215, 0, 0.6) 0%, rgba(255, 165, 0, 0.3) 40%, transparent 70%);
  animation: glow-pulse 2s ease-in-out infinite;
  animation-delay: 0.3s;
}

@keyframes glow-pulse {
  0%,
  100% {
    transform: translate(-50%, -50%) scale(0.8);
    opacity: 0.6;
  }

  50% {
    transform: translate(-50%, -50%) scale(1.3);
    opacity: 0.3;
  }
}

.confetti-burst {
  position: absolute;
  width: 100%;
  height: 100%;
  top: 0;
  left: 0;
}

.burst {
  position: absolute;
  width: 50rpx;
  height: 45rpx;
  top: 50%;
  left: 50%;
  transform-origin: center;
  animation-delay: 0.6s;
}

.burst-svg {
  width: 100%;
  height: 100%;
  overflow: visible;
}

.burst-1 {
  transform: translate(-50%, -50%) rotate(0deg);
  animation: burst-1 1.5s ease-out forwards;
}

.burst-2 {
  transform: translate(-50%, -50%) rotate(45deg);
  animation: burst-2 1.5s ease-out forwards;
}

.burst-3 {
  transform: translate(-50%, -50%) rotate(90deg);
  animation: burst-3 1.5s ease-out forwards;
}

.burst-4 {
  transform: translate(-50%, -50%) rotate(135deg);
  animation: burst-4 1.5s ease-out forwards;
}

.burst-5 {
  transform: translate(-50%, -50%) rotate(180deg);
  animation: burst-5 1.5s ease-out forwards;
}

.burst-6 {
  transform: translate(-50%, -50%) rotate(225deg);
  animation: burst-6 1.5s ease-out forwards;
}

.burst-7 {
  transform: translate(-50%, -50%) rotate(270deg);
  animation: burst-7 1.5s ease-out forwards;
}

.burst-8 {
  transform: translate(-50%, -50%) rotate(315deg);
  animation: burst-8 1.5s ease-out forwards;
}

@keyframes burst-1 {
  0% {
    transform: translate(-50%, -50%) rotate(0deg) translateX(0) scale(0);
    opacity: 0;
  }

  10% {
    transform: translate(-50%, -50%) rotate(0deg) translateX(20rpx) scale(1.2);
    opacity: 1;
  }

  100% {
    transform: translate(-50%, -50%) rotate(0deg) translateX(200rpx) scale(0.8);
