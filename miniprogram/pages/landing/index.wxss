  0% {
    opacity: 0;
    transform: scale(0);
  }

  25% {
    opacity: 1;
    transform: scale(1.2);
  }

  100% {
    opacity: 0;
    transform: scale(0.5) translateX(150rpx);
  }
}

.video-container {
  width: 100%;
  min-height: 100vh;
  background: linear-gradient(180deg, #000000 0%, #1a1a1a 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 32rpx;
  box-sizing: border-box;
}

.intro-video {
  width: 100%;
  height: 60vh;
  border-radius: 16rpx;
  background: #000000;
  margin-bottom: 60rpx;
}

.video-info {
  width: 100%;
  max-width: 600rpx;
  text-align: center;
}

.video-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 20rpx;
  font-family: 'Alibaba PuHuiTi Bold', 'PingFang SC', sans-serif;
}

.video-description {
  font-size: 28rpx;
  color: #cccccc;
  margin-bottom: 80rpx;
  line-height: 1.5;
  font-family: 'Alibaba PuHuiTi', 'PingFang SC', sans-serif;
}

.video-actions {
  width: 100%;
}

.action-hint {
  padding: 40rpx 0;
}

.hint-text {
  font-size: 24rpx;
  color: #999999;
  text-align: center;
  font-family: 'Alibaba PuHuiTi', 'PingFang SC', sans-serif;
}

.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  width: 100%;
}

.action-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 48rpx;
  box-sizing: border-box;
  position: relative;
  border: none;
  font-size: inherit;
  transition: all 0.3s ease;
}

.action-btn::after {
  border: none;
}

.primary-btn {
  background: linear-gradient(90deg, #2cedb8 0%, #1dd1a1 100%);
  box-shadow: 0 8rpx 24rpx rgba(44, 237, 184, 0.3);
}

.primary-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(44, 237, 184, 0.3);
}

.secondary-btn {
  background: rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.secondary-btn:active {
  transform: scale(0.98);
  background: rgba(255, 255, 255, 0.15);
}

.btn-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #000000;
  margin-right: 12rpx;
  font-family: 'Alibaba PuHuiTi Bold', 'PingFang SC', sans-serif;
}

.secondary-btn .btn-text {
  color: #ffffff;
}

.btn-icon {
  width: 32rpx;
  height: 32rpx;
}

.redirect-page {
  min-height: 100vh;
  background: transparent;
}
