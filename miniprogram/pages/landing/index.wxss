}

.action-button {
  width: 100%;
  max-width: 450rpx;
  height: 84rpx;
  background: #2cedb8;
  border-radius: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 44rpx;
  box-shadow: 0 4rpx 20rpx rgba(44, 237, 184, 0.3);
  transition: all 0.3s ease;
  position: relative;
}

.action-button:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(44, 237, 184, 0.3);
}

.button-text {
  font-size: 24rpx;
  color: #000000;
  font-weight: bold;
  letter-spacing: -0.72rpx;
  font-family: 'Alibaba PuHuiTi Bold', 'Alibaba PuHuiTi', 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
