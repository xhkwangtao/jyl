<view class="checkin-page">
  <permission-guard id="permissionGuard"></permission-guard>

  <view class="background-layer">
    <image class="background-svg" src="/images/ai-chat-bg.svg" mode="aspectFill"></image>
  </view>

  <view class="page-header">
    <universal-navigation
      title="{{pageTitle}}"
      show-back="{{true}}"
      showHomeButton="{{true}}"
      background-color="{{navBackground}}"
      theme="{{navTheme}}"
      showUserAvatar="{{false}}"
      useCapsuleStyle="{{false}}"
      useDefaultBack="{{false}}"
      bind:back="onBackTap"
      bind:home="onHomeTap"
    />
  </view>

  <view class="content-layer">
    <view class="rules-card" wx:if="{{!generatedReportReady}}">
      <view class="section-head section-head-static">
        <view>
          <text class="section-title">研学流程</text>
          <text class="section-caption">跟着下面的流程完成景点寻找、答题卡记录与研学报告生成。</text>
        </view>
      </view>

      <view class="rule-list">
        <view class="rule-item" wx:for="{{ruleList}}" wx:key="indexText">
          <view class="rule-index-shell">
            <text class="rule-index">{{item.indexText}}</text>
          </view>
          <view class="rule-copy">
            <text class="rule-title">{{item.title}}</text>
            <text class="rule-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="hero-card">
      <view class="hero-copy">
        <text class="hero-kicker">SECRET HUNT</text>
        <text class="hero-title">{{heroTitle}}</text>
        <text class="hero-desc">{{heroDesc}}</text>
      </view>

      <view class="hero-progress-row">
        <view class="hero-progress-copy">
          <text class="hero-progress-label">当前已记录</text>
          <text class="hero-progress-value">{{displayCollectedCount}} / {{totalCount}}</text>
        </view>
        <text class="hero-progress-percent">{{displayProgressPercentText}}</text>
      </view>

      <view class="progress-track">
        <view class="progress-fill" style="width: {{displayProgressPercent}}%;"></view>
      </view>

      <view class="stats-grid">
        <view class="stat-card">
          <text class="stat-label">全部暗号</text>
          <text class="stat-value">{{totalCount}}</text>
        </view>
        <view class="stat-card stat-card-checked">
          <text class="stat-label">已记录</text>
          <text class="stat-value">{{displayCollectedCount}}</text>
        </view>
        <view class="stat-card">
          <text class="stat-label">待寻找</text>
          <text class="stat-value">{{displayPendingCount}}</text>
        </view>
      </view>

      <view class="hero-actions">
        <view class="hero-action hero-action-primary" bindtap="onScanCollect">
          <text class="hero-action-text hero-action-text-primary">扫描答题卡</text>
        </view>
        <view class="hero-action hero-action-secondary" bindtap="onMyPageTap">
          <text class="hero-action-text hero-action-text-secondary">我的档案</text>
        </view>
      </view>

      <text class="scan-tip" wx:if="{{scanTip}}">{{scanTip}}</text>
    </view>

    <view class="generated-report-card" wx:if="{{generatedReportReady}}">
      <view class="generated-report-chip">
        <text class="generated-report-chip-text">研学报告已生成</text>
      </view>
      <text class="generated-report-title">{{generatedReportPdfTitle}}</text>
      <text class="generated-report-desc">{{generatedReportDescText}}</text>
      <text class="generated-report-meta" wx:if="{{generatedReportGeneratedAtText}}">生成时间 {{generatedReportGeneratedAtText}}</text>
      <text class="generated-report-warning" wx:if="{{generatedReportWarningText}}">提示：{{generatedReportWarningText}}</text>

      <view class="generated-report-actions">
        <view class="generated-report-action generated-report-action-primary" bindtap="onPreviewGeneratedReportTap">
          <text class="generated-report-action-text generated-report-action-text-primary">查看报告</text>
        </view>
        <view class="generated-report-action generated-report-action-secondary" bindtap="onSaveGeneratedReportTap">
          <text class="generated-report-action-text generated-report-action-text-secondary">{{reportPosterSaving ? '生成中...' : '保存报告'}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="worksheet-dialog-mask" wx:if="{{showWorksheetDialog}}">
    <view class="worksheet-dialog" catchtap="noop">
      <text class="worksheet-dialog-title">扫描答题卡</text>
      <text class="worksheet-dialog-desc">请先填写编号和姓名，随后打开摄像头拍摄已完成填写的答题卡。</text>

      <view class="worksheet-field">
        <text class="worksheet-field-label">编号</text>
        <input
          class="worksheet-field-input"
          placeholder="请输入编号"
          maxlength="80"
          value="{{worksheetStudentCode}}"
          data-field="worksheetStudentCode"
          bindinput="onWorksheetInput"
        />
      </view>

      <view class="worksheet-field">
        <text class="worksheet-field-label">姓名</text>
        <input
          class="worksheet-field-input"
          placeholder="请输入姓名"
          maxlength="60"
          value="{{worksheetStudentName}}"
          data-field="worksheetStudentName"
          bindinput="onWorksheetInput"
        />
      </view>

      <view class="worksheet-dialog-actions">
        <view class="worksheet-dialog-action worksheet-dialog-action-secondary" bindtap="onWorksheetDialogClose">
          <text class="worksheet-dialog-action-text worksheet-dialog-action-text-secondary">取消</text>
        </view>
        <view class="worksheet-dialog-action worksheet-dialog-action-primary" bindtap="onWorksheetDialogConfirm">
          <text class="worksheet-dialog-action-text worksheet-dialog-action-text-primary">去拍照</text>
        </view>
      </view>
    </view>
  </view>

  <canvas
    id="study-report-poster-canvas"
    type="2d"
    class="report-poster-canvas"
    style="width: 1192px; height: 1680px;"
  />
</view>
