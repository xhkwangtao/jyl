.checkin-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
}

.background-layer {
  position: fixed;
  inset: 0;
  z-index: 0;
}

.background-svg {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  pointer-events: none;
}

.page-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 4;
  padding: 32rpx 24rpx 0;
}

.content-layer {
  position: relative;
  z-index: 2;
  box-sizing: border-box;
  padding: calc(208rpx + constant(safe-area-inset-top)) 32rpx calc(72rpx + constant(safe-area-inset-bottom));
  padding: calc(208rpx + env(safe-area-inset-top)) 32rpx calc(72rpx + env(safe-area-inset-bottom));
}

.hero-card,
.generated-report-card,
.rules-card,
.filter-shell,
.spot-card,
.empty-state {
  position: relative;
  overflow: hidden;
  border-radius: 32rpx;
  border: 1px solid rgba(36, 72, 92, 0.1);
  background: rgba(255, 251, 246, 0.95);
  box-shadow: 0 18rpx 44rpx rgba(31, 58, 74, 0.1);
}

.hero-card::before,
.generated-report-card::before,
.rules-card::before,
.spot-card::before,
.empty-state::before {
  content: '';
  position: absolute;
  inset: 0;
  pointer-events: none;
  background:
    radial-gradient(circle at top right, rgba(45, 123, 122, 0.12), transparent 28%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.28), transparent 35%);
}

.hero-card {
  padding: 28rpx 28rpx 30rpx;
  background:
    radial-gradient(circle at top right, rgba(47, 128, 125, 0.08), transparent 32%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.64) 0%, rgba(255, 250, 243, 0.92) 100%);
}

.rules-card {
  margin-top: 24rpx;
  padding: 28rpx;
  background: rgba(255, 251, 246, 0.95);
}

.generated-report-card {
  position: relative;
  margin-top: 24rpx;
  padding: 28rpx;
  overflow: hidden;
  border-radius: 32rpx;
  border: 1px solid rgba(36, 72, 92, 0.1);
  background:
    radial-gradient(circle at top right, rgba(44, 237, 184, 0.12), transparent 30%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.82) 0%, rgba(239, 255, 249, 0.96) 100%);
  box-shadow: 0 18rpx 44rpx rgba(31, 58, 74, 0.1);
}

.hero-copy,
.hero-progress-row,
.stats-grid,
.generated-report-chip,
.generated-report-title,
.generated-report-desc,
.generated-report-meta,
.generated-report-warning,
.generated-report-actions,
.section-head,
.spot-card-top,
.spot-bottom-row {
  position: relative;
  z-index: 1;
}

.hero-kicker {
  display: block;
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: #6f8d93;
}

.hero-title {
  display: block;
  margin-top: 12rpx;
  font-size: 42rpx;
  line-height: 1.24;
  font-weight: 700;
  color: #1f2d35;
}

.hero-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #5c6d74;
}

.hero-progress-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 28rpx;
}

.hero-progress-copy {
  min-width: 0;
}

.hero-progress-label {
  display: block;
  font-size: 22rpx;
  color: #7a8d92;
}

.hero-progress-value {
  display: block;
  margin-top: 6rpx;
  font-size: 40rpx;
  line-height: 1;
  font-weight: 700;
  color: #1f2d35;
}

.hero-progress-percent {
  flex-shrink: 0;
  font-size: 24rpx;
  font-weight: 700;
  color: #1f6a67;
}

.progress-track {
  position: relative;
  z-index: 1;
  height: 16rpx;
  margin-top: 20rpx;
  border-radius: 999rpx;
  background: rgba(45, 123, 122, 0.12);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #2cedb8 0%, #2f807d 100%);
}

.hero-actions {
  position: relative;
  z-index: 1;
  display: flex;
  gap: 14rpx;
  margin-top: 24rpx;
}

.hero-action {
  flex: 1;
  min-height: 82rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-action-primary {
  background: linear-gradient(180deg, #2f807d 0%, #245f6d 100%);
  box-shadow: 0 14rpx 26rpx rgba(36, 95, 109, 0.14);
}

.hero-action-secondary {
  background: rgba(255, 255, 255, 0.96);
  border: 1px solid rgba(45, 123, 122, 0.12);
}

.hero-action-text {
  font-size: 24rpx;
  font-weight: 700;
}

.hero-action-text-primary {
  color: #ffffff;
}

.hero-action-text-secondary {
  color: #245f6d;
}

.scan-tip {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 16rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #70828a;
}

.manual-tip {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 10rpx;
  font-size: 20rpx;
  line-height: 1.6;
}

.manual-tip-testing {
  color: #b06b2f;
}

.manual-tip-live {
  color: #60717b;
}

.report-poster-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 1192px;
  height: 1680px;
  opacity: 0;
  pointer-events: none;
}

.generated-report-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(44, 237, 184, 0.18);
}

.generated-report-chip-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #1f6a67;
}

.generated-report-title {
  display: block;
  margin-top: 18rpx;
  font-size: 34rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #1f2d35;
}

.generated-report-desc,
.generated-report-meta,
.generated-report-warning {
  display: block;
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.7;
}

.generated-report-desc,
.generated-report-meta {
  color: #5c6d74;
}

.generated-report-warning {
  color: #a96835;
}

.generated-report-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 22rpx;
}

.generated-report-action {
  flex: 1;
  min-height: 82rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.generated-report-action-primary {
  background: linear-gradient(180deg, #2f807d 0%, #245f6d 100%);
  box-shadow: 0 14rpx 26rpx rgba(36, 95, 109, 0.14);
}

.generated-report-action-secondary {
  background: rgba(255, 255, 255, 0.96);
  border: 1px solid rgba(45, 123, 122, 0.12);
}

.generated-report-action-text {
  font-size: 24rpx;
  font-weight: 700;
}

.generated-report-action-text-primary {
  color: #ffffff;
}

.generated-report-action-text-secondary {
  color: #245f6d;
}

.stats-grid {
  display: flex;
  gap: 14rpx;
  margin-top: 24rpx;
}

.stat-card {
  flex: 1;
  min-width: 0;
  padding: 20rpx 18rpx 22rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fdfcf9 0%, #eef5f3 100%);
  border: 1px solid rgba(45, 123, 122, 0.08);
}

.stat-card-checked {
  background: linear-gradient(180deg, rgba(44, 237, 184, 0.2) 0%, rgba(228, 255, 248, 0.95) 100%);
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #7a8d92;
}

.stat-value {
  display: block;
  margin-top: 10rpx;
  font-size: 32rpx;
  line-height: 1;
  font-weight: 700;
  color: #1f2d35;
}

.filter-shell {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 24rpx;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.78);
  backdrop-filter: blur(20rpx);
}

.filter-chip {
  flex: 1;
  min-width: 0;
  min-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: rgba(47, 128, 125, 0.08);
  transition: all 0.2s ease;
}

.filter-chip-active {
  background: linear-gradient(180deg, #2f807d 0%, #245f6d 100%);
  box-shadow: 0 16rpx 32rpx rgba(36, 95, 109, 0.2);
}

.filter-chip-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #245f6d;
}

.filter-chip-active .filter-chip-text {
  color: #ffffff;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 26rpx;
  padding: 0 6rpx;
}

.section-head-static {
  margin-top: 0;
  padding: 0;
}

.section-title {
  display: block;
  font-size: 32rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #1f2d35;
}

.section-caption,
.section-right {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #6f8d93;
}

.section-right {
  margin-top: 0;
  flex-shrink: 0;
}

.rule-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 24rpx;
}

.rule-item {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.rule-index-shell {
  width: 70rpx;
  height: 70rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #2f807d 0%, #245f6d 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.rule-index {
  font-size: 24rpx;
  font-weight: 700;
  color: #ffffff;
}

.rule-copy {
  flex: 1;
  min-width: 0;
}

.rule-title {
  display: block;
  font-size: 28rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #1f2d35;
}

.rule-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: #5c6d74;
}

.spot-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 20rpx;
}

.spot-card {
  padding: 24rpx;
}

.spot-card-checked {
  border-color: rgba(44, 237, 184, 0.22);
}

.spot-card-focused {
  border-color: rgba(36, 95, 109, 0.28);
  box-shadow: 0 0 0 3rpx rgba(47, 128, 125, 0.12), 0 20rpx 46rpx rgba(31, 58, 74, 0.14);
}

.spot-card-top {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.spot-sequence {
  width: 76rpx;
  height: 76rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fbf6ef 0%, #f4ecdf 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.spot-card-checked .spot-sequence {
  background: linear-gradient(180deg, #2f807d 0%, #245f6d 100%);
  box-shadow: 0 14rpx 26rpx rgba(36, 95, 109, 0.16);
}

.spot-sequence-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #c27d42;
}

.spot-card-checked .spot-sequence-text {
  color: #ffffff;
}

.spot-copy {
  flex: 1;
  min-width: 0;
}

.spot-meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.spot-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.spot-tag-forest {
  background: rgba(47, 128, 125, 0.12);
  color: #1f6a67;
}

.spot-tag-teal {
  background: rgba(45, 123, 122, 0.12);
  color: #21646f;
}

.spot-tag-stone {
  background: rgba(96, 106, 120, 0.12);
  color: #55606b;
}

.spot-tag-gold {
  background: rgba(196, 133, 75, 0.14);
  color: #a96835;
}

.spot-status {
  flex-shrink: 0;
  min-height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.spot-status-checked {
  background: rgba(44, 237, 184, 0.18);
}

.spot-status-pending {
  background: rgba(16, 24, 40, 0.06);
}

.spot-status-text {
  font-size: 20rpx;
  font-weight: 700;
  color: #1f2d35;
}

.spot-status-checked .spot-status-text {
  color: #19886a;
}

.spot-status-pending .spot-status-text {
  color: #60717b;
}

.spot-title {
  display: block;
  margin-top: 12rpx;
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #1f2d35;
}

.spot-location-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 12rpx;
}

.spot-location-icon {
  width: 26rpx;
  height: 26rpx;
  flex-shrink: 0;
}

.spot-location-text {
  min-width: 0;
  font-size: 22rpx;
  line-height: 1.5;
  color: #245f6d;
}

.spot-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #5c6d74;
}

.spot-bottom-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 22rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(16, 24, 40, 0.08);
}

.spot-time {
  min-width: 0;
  font-size: 22rpx;
  line-height: 1.5;
  color: #70828a;
}

.spot-time-checked {
  color: #19886a;
}

.spot-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.spot-action {
  min-width: 148rpx;
  min-height: 68rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.spot-action-ghost {
  background: rgba(255, 255, 255, 0.96);
  border: 1px solid rgba(45, 123, 122, 0.12);
}

.spot-action-disabled {
  background: rgba(16, 24, 40, 0.04);
  border-color: rgba(16, 24, 40, 0.06);
}

.spot-action-primary {
  background: linear-gradient(180deg, #2f807d 0%, #245f6d 100%);
  box-shadow: 0 12rpx 24rpx rgba(36, 95, 109, 0.12);
}

.spot-action-test-primary {
  background: linear-gradient(180deg, #c9854b 0%, #a96835 100%);
  box-shadow: 0 12rpx 24rpx rgba(169, 104, 53, 0.16);
}

.spot-action-secondary {
  background: rgba(16, 24, 40, 0.06);
}

.spot-action-test-secondary {
  background: rgba(201, 133, 75, 0.12);
  border: 1px solid rgba(201, 133, 75, 0.16);
}

.spot-action-text {
  font-size: 22rpx;
  font-weight: 700;
}

.spot-action-text-ghost,
.spot-action-text-secondary {
  color: #245f6d;
}

.spot-action-text-disabled {
  color: #8d98a2;
}

.spot-action-text-primary {
  color: #ffffff;
}

.spot-action-text-test-primary {
  color: #ffffff;
}

.spot-action-text-test-secondary {
  color: #a96835;
}

.empty-state {
  margin-top: 20rpx;
  padding: 40rpx 32rpx;
  text-align: center;
}

.empty-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2d35;
}

.empty-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #70828a;
}

.worksheet-dialog-mask {
  position: fixed;
  inset: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background: rgba(16, 24, 40, 0.42);
  box-sizing: border-box;
}

.worksheet-dialog {
  width: 100%;
  max-width: 640rpx;
  padding: 34rpx 30rpx 30rpx;
  border-radius: 32rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(255, 250, 243, 0.98) 100%);
  box-shadow: 0 24rpx 52rpx rgba(16, 24, 40, 0.18);
  box-sizing: border-box;
}

.worksheet-dialog-title {
  display: block;
  font-size: 34rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #1f2d35;
}

.worksheet-dialog-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: #5c6d74;
}

.worksheet-field {
  margin-top: 22rpx;
}

.worksheet-field-label {
  display: block;
  font-size: 22rpx;
  font-weight: 700;
  color: #245f6d;
}

.worksheet-field-input {
  width: 100%;
  min-height: 88rpx;
  margin-top: 12rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: rgba(245, 248, 247, 0.98);
  border: 1px solid rgba(45, 123, 122, 0.12);
  box-sizing: border-box;
  font-size: 24rpx;
  color: #1f2d35;
}

.worksheet-dialog-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 28rpx;
}

.worksheet-dialog-action {
  flex: 1;
  min-height: 82rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.worksheet-dialog-action-primary {
  background: linear-gradient(180deg, #2f807d 0%, #245f6d 100%);
  box-shadow: 0 14rpx 26rpx rgba(36, 95, 109, 0.14);
}

.worksheet-dialog-action-secondary {
  background: rgba(255, 255, 255, 0.96);
  border: 1px solid rgba(45, 123, 122, 0.12);
}

.worksheet-dialog-action-text {
  font-size: 24rpx;
  font-weight: 700;
}

.worksheet-dialog-action-text-primary {
  color: #ffffff;
}

.worksheet-dialog-action-text-secondary {
  color: #245f6d;
}

@media (max-width: 375px) {
  .content-layer {
    padding-left: 24rpx;
    padding-right: 24rpx;
  }

  .hero-title {
    font-size: 38rpx;
  }

  .stats-grid,
  .hero-actions,
  .generated-report-actions,
  .worksheet-dialog-actions,
  .spot-bottom-row {
    flex-wrap: wrap;
  }

  .spot-actions {
    width: 100%;
    justify-content: flex-end;
  }

  .hero-action {
    min-width: 100%;
  }
}
