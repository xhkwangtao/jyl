<page-meta page-style="{{pageStyle}}"></page-meta>

<view class="staff-report-page" style="{{navBarHeightStyle}}">
  <view class="background-layer">
    <image class="background-svg" src="/images/ai-chat-bg.svg" mode="aspectFill"></image>
  </view>

  <view class="page-header">
    <universal-navigation
      title="{{pageTitle}}"
      show-back="{{true}}"
      showHomeButton="{{true}}"
      background-color="rgba(255,255,255,0.9)"
      title-color="#243949"
      showUserAvatar="{{false}}"
      useCapsuleStyle="{{false}}"
      useDefaultBack="{{false}}"
      bind:back="onBackTap"
      bind:home="onHomeTap"
    />
  </view>

  <view class="content-layer" wx:if="{{pageReady}}">
    <view class="hero-card">
      <text class="hero-kicker">STAFF MODE</text>
      <text class="hero-title">工作人员答题卡识别</text>
      <text class="hero-desc">请选择当前研学团，再拍摄答题卡生成对应研学报告。</text>
    </view>

    <view class="panel-card">
      <view class="section-head">
        <text class="section-title">选择研学团</text>
        <text class="section-desc">仅展示当前可操作的 active 研学团</text>
      </view>

      <picker
        mode="selector"
        range="{{groupList}}"
        range-key="displayName"
        value="{{selectedGroupIndex}}"
        bindchange="onGroupChange"
        disabled="{{groupLoading || !groupList.length}}"
      >
        <view class="picker-field">
          <text class="picker-field-text {{selectedGroupName ? '' : 'picker-field-placeholder'}}">
            {{selectedGroupName || (groupLoading ? '研学团加载中...' : '请选择研学团')}}
          </text>
          <text class="picker-field-arrow">></text>
        </view>
      </picker>

      <view class="group-stats" wx:if="{{selectedGroupName}}">
        <view class="stat-chip">
          <text class="stat-chip-label">学生</text>
          <text class="stat-chip-value">{{selectedGroupStudentCount}}</text>
        </view>
        <view class="stat-chip">
          <text class="stat-chip-label">已扫码</text>
          <text class="stat-chip-value">{{selectedGroupScannedCount}}</text>
        </view>
        <view class="stat-chip">
          <text class="stat-chip-label">已生成</text>
          <text class="stat-chip-value">{{selectedGroupGeneratedCount}}</text>
        </view>
      </view>

      <text class="group-meta" wx:if="{{selectedGroupMetaText}}">{{selectedGroupMetaText}}</text>
    </view>

    <view class="panel-card">
      <view class="section-head">
        <text class="section-title">学生查询</text>
        <text class="section-desc">输入 1 到 3 位答题卡编号，查询当前研学团学生</text>
      </view>

      <view class="field-row">
        <input
          class="field-input"
          type="number"
          maxlength="3"
          placeholder="请输入答题卡编号"
          value="{{cardCode}}"
          bindinput="onCardCodeInput"
        />
        <view class="field-button" bindtap="onLookupStudentTap">
          <text class="field-button-text">{{studentLookupLoading ? '查询中...' : '查询学生'}}</text>
        </view>
      </view>

      <view class="student-card" wx:if="{{currentStudent}}">
        <view class="student-card-top">
          <view>
            <text class="student-name">{{currentStudent.student_name}}</text>
            <text class="student-code">答题卡编号 {{currentStudent.card_code}}</text>
          </view>
          <view class="student-status-badge">
            <text class="student-status-badge-text">{{currentStudentReportStatusText}}</text>
          </view>
        </view>
        <text class="student-meta" wx:if="{{currentStudentClassText}}">{{currentStudentClassText}}</text>
        <text class="student-meta" wx:if="{{currentStudentTimeText}}">{{currentStudentTimeText}}</text>

        <view class="student-actions">
          <view class="student-action student-action-primary" bindtap="onCaptureWorksheetTap">
            <text class="student-action-text student-action-text-primary">{{taskRunning ? '处理中...' : '拍摄答题卡'}}</text>
          </view>
          <view class="student-action student-action-secondary" bindtap="onRefreshStudentStatusTap">
            <text class="student-action-text student-action-text-secondary">刷新状态</text>
          </view>
        </view>
      </view>
    </view>

    <view class="panel-card" wx:if="{{selectedGroupId}}">
      <view class="section-head">
        <text class="section-title">学生列表</text>
        <text class="section-desc">右侧可直接扫描答题卡，生成结果会在列表中实时显示</text>
      </view>

      <view class="student-list-loading" wx:if="{{studentListLoading}}">
        <text class="student-list-loading-text">学生列表加载中...</text>
      </view>

      <view class="student-list" wx:elif="{{studentList.length}}">
        <view class="student-list-item" wx:for="{{studentList}}" wx:key="card_code">
          <view class="student-list-item-top">
            <view class="student-list-copy">
              <text class="student-list-name">{{item.student_name}}</text>
              <text class="student-list-meta">答题卡编号 {{item.card_code}}</text>
              <text class="student-list-meta" wx:if="{{item.classText}}">{{item.classText}}</text>
            </view>

            <view
              class="student-list-scan-button {{item.isTaskRunning ? 'student-list-scan-button-disabled' : ''}}"
              bindtap="onStudentScanTap"
              data-card-code="{{item.card_code}}"
            >
              <text class="student-list-scan-button-text">{{item.actionText}}</text>
            </view>
          </view>

          <view class="student-list-status-row">
            <view class="student-list-status-badge student-list-status-badge-{{item.uiTaskTone}}">
              <text class="student-list-status-badge-text">{{item.uiTaskText}}</text>
            </view>
          </view>

          <text class="student-list-hint student-list-hint-{{item.uiTaskTone}}" wx:if="{{item.uiHintText}}">
            {{item.uiHintText}}
          </text>

          <text class="student-list-time" wx:if="{{item.timeText}}">{{item.timeText}}</text>
        </view>
      </view>

      <view class="student-list-empty" wx:else>
        <text class="student-list-empty-text">当前研学团暂无学生数据</text>
      </view>
    </view>

    <view class="status-card" wx:if="{{taskStatusText}}">
      <text class="status-label">当前任务状态</text>
      <text class="status-value status-value-{{taskStatusTone}}">{{taskStatusText}}</text>
      <text class="status-desc" wx:if="{{taskHintText}}">{{taskHintText}}</text>
    </view>

    <view class="empty-card" wx:if="{{!groupLoading && !groupList.length}}">
      <text class="empty-title">暂无可操作研学团</text>
      <text class="empty-desc">当前账号下没有 active 状态的研学团，或暂时没有权限操作。</text>
    </view>
  </view>
</view>
