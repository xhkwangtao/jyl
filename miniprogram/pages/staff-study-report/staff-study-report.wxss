.staff-report-page {
  min-height: 100vh;
}

.background-layer {
  position: fixed;
  inset: 0;
  z-index: 0;
}

.background-svg {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  pointer-events: none;
}

.page-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 6;
  padding: 32rpx 24rpx 0;
}

.content-layer {
  position: relative;
  z-index: 2;
  box-sizing: border-box;
  padding: calc(208rpx + constant(safe-area-inset-top)) 32rpx calc(72rpx + constant(safe-area-inset-bottom));
  padding: calc(208rpx + env(safe-area-inset-top)) 32rpx calc(72rpx + env(safe-area-inset-bottom));
}

.hero-card,
.panel-card,
.status-card,
.empty-card {
  position: relative;
  overflow: hidden;
  border-radius: 32rpx;
  border: 1px solid rgba(36, 72, 92, 0.1);
  background: rgba(255, 251, 246, 0.95);
  box-shadow: 0 18rpx 44rpx rgba(31, 58, 74, 0.1);
}

.hero-card::before,
.panel-card::before,
.status-card::before,
.empty-card::before {
  content: '';
  position: absolute;
  inset: 0;
  pointer-events: none;
  background:
    radial-gradient(circle at top right, rgba(45, 123, 122, 0.12), transparent 28%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.28), transparent 35%);
}

.hero-card,
.panel-card,
.status-card,
.empty-card {
  margin-bottom: 24rpx;
  padding: 28rpx;
}

.hero-kicker,
.hero-title,
.hero-desc,
.section-head,
.picker-field,
.group-stats,
.group-meta,
.field-row,
.student-card,
.status-label,
.status-value,
.status-desc,
.empty-title,
.empty-desc {
  position: relative;
  z-index: 1;
}

.hero-kicker {
  display: block;
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: #6f8d93;
}

.hero-title {
  display: block;
  margin-top: 12rpx;
  font-size: 40rpx;
  line-height: 1.24;
  font-weight: 700;
  color: #1f2d35;
}

.hero-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #5c6d74;
}

.section-head {
  margin-bottom: 18rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #243949;
}

.section-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #71838d;
}

.picker-field {
  min-height: 88rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1px solid rgba(36, 72, 92, 0.08);
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.picker-field-text {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  color: #243949;
}

.picker-field-placeholder {
  color: #9aa8ae;
}

.picker-field-arrow {
  flex-shrink: 0;
  font-size: 28rpx;
  color: #7c919a;
  transform: rotate(90deg);
}

.group-stats {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.stat-chip {
  flex: 1;
  min-width: 0;
  padding: 18rpx 16rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 1px solid rgba(36, 72, 92, 0.06);
}

.stat-chip-label {
  display: block;
  font-size: 20rpx;
  color: #78909a;
}

.stat-chip-value {
  display: block;
  margin-top: 6rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2d35;
}

.group-meta {
  display: block;
  margin-top: 14rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #6d8088;
}

.field-row {
  display: flex;
  gap: 16rpx;
}

.field-input {
  flex: 1;
  min-width: 0;
  min-height: 88rpx;
  box-sizing: border-box;
  padding: 0 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1px solid rgba(36, 72, 92, 0.08);
  font-size: 28rpx;
  color: #243949;
}

.field-button {
  flex-shrink: 0;
  min-width: 176rpx;
  min-height: 88rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #2f807d 0%, #245f6d 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 14rpx 26rpx rgba(36, 95, 109, 0.14);
}

.field-button-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #ffffff;
}

.student-card {
  margin-top: 22rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.84);
  border: 1px solid rgba(36, 72, 92, 0.08);
}

.student-list-loading,
.student-list-empty {
  padding: 32rpx 0 12rpx;
}

.student-list-loading-text,
.student-list-empty-text {
  display: block;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6f848c;
  text-align: center;
}

.student-list-item {
  position: relative;
  z-index: 1;
  padding: 24rpx 0;
  border-bottom: 1px solid rgba(36, 72, 92, 0.08);
}

.student-list-item:last-child {
  padding-bottom: 6rpx;
  border-bottom: 0;
}

.student-list-item-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.student-list-copy {
  flex: 1;
  min-width: 0;
}

.student-list-name {
  display: block;
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #243949;
}

.student-list-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #6f828b;
}

.student-list-scan-button {
  flex-shrink: 0;
  min-width: 156rpx;
  min-height: 72rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #2f807d 0%, #245f6d 100%);
  box-shadow: 0 10rpx 22rpx rgba(36, 95, 109, 0.14);
  display: flex;
  align-items: center;
  justify-content: center;
}

.student-list-scan-button-disabled {
  background: linear-gradient(180deg, #9fb5b6 0%, #88a2aa 100%);
  box-shadow: none;
}

.student-list-scan-button-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #ffffff;
  white-space: nowrap;
}

.student-list-status-row {
  margin-top: 16rpx;
}

.student-list-status-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
}

.student-list-status-badge-idle {
  background: rgba(36, 95, 109, 0.08);
}

.student-list-status-badge-running {
  background: rgba(185, 119, 14, 0.12);
}

.student-list-status-badge-success {
  background: rgba(31, 143, 97, 0.12);
}

.student-list-status-badge-error {
  background: rgba(196, 65, 50, 0.12);
}

.student-list-status-badge-text {
  font-size: 20rpx;
  font-weight: 700;
  color: #245f6d;
}

.student-list-status-badge-running .student-list-status-badge-text {
  color: #b9770e;
}

.student-list-status-badge-success .student-list-status-badge-text {
  color: #1f8f61;
}

.student-list-status-badge-error .student-list-status-badge-text {
  color: #c44132;
}

.student-list-hint,
.student-list-time {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #73858e;
}

.student-list-hint-running {
  color: #9b6f19;
}

.student-list-hint-success {
  color: #197754;
}

.student-list-hint-error {
  color: #b53f33;
}

.student-card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.student-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #243949;
}

.student-code,
.student-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #6e8089;
}

.student-status-badge {
  flex-shrink: 0;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(36, 95, 109, 0.08);
}

.student-status-badge-text {
  font-size: 20rpx;
  font-weight: 700;
  color: #245f6d;
}

.student-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 22rpx;
}

.student-action {
  flex: 1;
  min-height: 82rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.student-action-primary {
  background: linear-gradient(180deg, #2f807d 0%, #245f6d 100%);
  box-shadow: 0 14rpx 26rpx rgba(36, 95, 109, 0.14);
}

.student-action-secondary {
  background: rgba(255, 255, 255, 0.96);
  border: 1px solid rgba(45, 123, 122, 0.12);
}

.student-action-text {
  font-size: 24rpx;
  font-weight: 700;
}

.student-action-text-primary {
  color: #ffffff;
}

.student-action-text-secondary {
  color: #245f6d;
}

.status-label {
  display: block;
  font-size: 22rpx;
  color: #758993;
}

.status-value {
  display: block;
  margin-top: 8rpx;
  font-size: 34rpx;
  line-height: 1.35;
  font-weight: 700;
}

.status-value-idle {
  color: #245f6d;
}

.status-value-running {
  color: #b9770e;
}

.status-value-success {
  color: #1f8f61;
}

.status-value-error {
  color: #c44132;
}

.status-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #71838d;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #243949;
}

.empty-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6d8088;
}
