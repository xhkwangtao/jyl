<view class="map-page {{navigationActive ? 'navigation-mode' : ''}}">
  <universal-navigation
    title=""
    backgroundColor="rgba(0, 0, 0, 0.0)"
    showHomeButton="{{false}}"
    showUserAvatar="{{false}}"
    useCapsuleStyle="{{true}}"
    theme="light"
    useDefaultBack="{{false}}"
    bind:back="onStatusBarBack"
    bind:user="goToUserPage"
  />

  <view class="map-container" style="padding-top: {{navigationBarTotalHeight}}px;">
    <view class="gradient-background-container">
      <view class="gradient-bg-main"></view>
      <view class="gradient-bg-blur1"></view>
      <view class="gradient-bg-blur2"></view>
      <view class="gradient-bg-blur3"></view>
      <view class="gradient-bg-blur4"></view>
      <view class="gradient-bg-blur5"></view>
    </view>

    <audio-player-guide
      id="audioPlayerGuide"
      visible="{{showAudioPlayer && (!navigationActive || navigationAudioMode === 'full')}}"
      current-poi="{{currentAudioPoi}}"
      user-score="{{userScore}}"
      user-rank-percent="{{userRankPercent}}"
      show-progress="{{showAudioProgress}}"
      bind:audioPlay="onAudioPlay"
      bind:audioPause="onAudioPause"
      bind:audioStop="onAudioStop"
      bind:audioEnded="onAudioEnded"
      bind:audioTimeUpdate="onAudioTimeUpdate"
      bind:close="onCloseAudioPlayer"
    />

    <view class="top-toolbar-container {{!showAudioPlayer ? 'no-audio-player' : ''}}" wx:if="{{!navigationActive}}">
      <poi-filter
        id="poiFilter"
        visible="{{showPoiFilter}}"
        default-filter="{{currentPoiFilter}}"
        bind:filterChange="onPoiFilterChange"
      />
    </view>

    <map-core
      longitude="{{longitude}}"
      latitude="{{latitude}}"
      scale="{{scale}}"
      show-location="{{showLocation}}"
      enable-p-o-i="{{enablePOI}}"
      markers="{{allMarkers}}"
      polyline="{{polylineData}}"
      boundary-limit="{{mapBoundaryLimit}}"
      allowed-zooms="{{allowedZooms}}"
      bind:mapReady="onMapReady"
      bind:regionChange="onRegionChange"
      bind:scaleUpdate="onScaleUpdate"
      bind:mapTap="onMapTap"
      bind:markerTap="onMarkerTap"
      bind:poiTap="onPOITap"
    />

    <view class="intelligent-route-button-wrapper" wx:if="{{!navigationActive}}">
      <gradient-button bind:tap="onIntelligentRoutePlanning">
        <image class="button-icon" src="/images/icons/intelligent-route.svg" mode="aspectFit"></image>
        <text>{{intelligentRoutePlanningText}}</text>
      </gradient-button>
    </view>

    <view
      class="audio-list-floating-button"
      wx:if="{{audioPoiList.length > 0}}"
      bindtap="onToggleAudioListDrawer"
    >
      <image class="audio-list-icon" src="/images/icons/voice-static.svg" mode="aspectFit"></image>
    </view>

    <intelligent-route-planner
      visible="{{showIntelligentPlanner}}"
      routes="{{plannerRoutes}}"
      selected-route-id="{{selectedIntelligentRouteId}}"
      bind:routeSelected="onIntelligentRouteSelected"
      bind:close="onCloseIntelligentPlanner"
    />

    <poi-audio-list
      visible="{{showAudioListDrawer}}"
      poi-list="{{audioPoiList}}"
      current-poi="{{currentAudioPoi}}"
      bind:close="onCloseAudioListDrawer"
      bind:select="onSelectAudioFromList"
    />
  </view>
</view>
