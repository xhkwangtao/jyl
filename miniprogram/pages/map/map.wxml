<view class="map-page {{navigationActive ? 'navigation-mode' : ''}}">
  <universal-navigation
    title=""
    backgroundColor="rgba(0, 0, 0, 0.0)"
    showHomeButton="{{false}}"
    showUserAvatar="{{false}}"
    useCapsuleStyle="{{true}}"
    theme="light"
    useDefaultBack="{{false}}"
    bind:back="onStatusBarBack"
    bind:user="goToUserPage"
  />

  <view class="map-container" style="padding-top: {{navigationBarTotalHeight}}px;">
    <view class="gradient-background-container">
      <view class="gradient-bg-main"></view>
      <view class="gradient-bg-blur1"></view>
      <view class="gradient-bg-blur2"></view>
      <view class="gradient-bg-blur3"></view>
      <view class="gradient-bg-blur4"></view>
      <view class="gradient-bg-blur5"></view>
    </view>

    <audio-player-guide
      id="audioPlayerGuide"
      visible="{{showAudioPlayer && (!navigationActive || navigationAudioMode === 'full')}}"
      keep-playing-when-hidden="{{navigationActive && navigationAudioMode === 'mini'}}"
      current-poi="{{currentAudioPoi}}"
      user-score="{{userScore}}"
      user-rank-percent="{{userRankPercent}}"
      show-progress="{{showAudioProgress}}"
      bind:audioPlay="onAudioPlay"
      bind:audioPause="onAudioPause"
      bind:audioStop="onAudioStop"
      bind:audioEnded="onAudioEnded"
      bind:audioTimeUpdate="onAudioTimeUpdate"
      bind:playStateChange="onAudioPlayStateChange"
      bind:requestPlay="onAudioPlayerRequestPlay"
      bind:openAIChat="onOpenAIChat"
      bind:close="onCloseAudioPlayer"
    />

    <view class="mini-audio-player" wx:if="{{navigationActive && showAudioPlayer && navigationAudioMode === 'mini' && currentAudioPoi}}">
      <view class="mini-audio-player-main" bindtap="onRestoreFullAudioPlayer">
        <view class="mini-audio-player-avatar">
          <image class="mini-audio-player-avatar-image" src="/images/ai-assistant-xiaoying.png" mode="aspectFit"></image>
        </view>
        <view class="mini-audio-player-copy">
          <text class="mini-audio-player-title">{{currentAudioPoi.name || currentAudioPoi.displayName || '景点讲解'}}</text>
          <text class="mini-audio-player-subtitle">{{audioMuted ? '讲解已静音，点击展开' : (audioPlaying ? '讲解播放中' : '讲解已暂停，点击展开')}}</text>
        </view>
      </view>
      <view class="mini-audio-player-actions">
        <view class="mini-audio-player-action mini-audio-player-action-secondary" catchtap="onMiniAudioToggleVolume">
          <text class="mini-audio-player-action-text mini-audio-player-action-text-secondary">{{audioMuted ? '开声' : '静音'}}</text>
        </view>
        <view class="mini-audio-player-action" catchtap="onMiniAudioPlayPause">
          <text class="mini-audio-player-action-text">{{audioPlaying ? '暂停' : '播放'}}</text>
        </view>
        <view class="mini-audio-player-action mini-audio-player-action-ghost" catchtap="onCloseMiniAudioPlayer">
          <text class="mini-audio-player-action-text mini-audio-player-action-text-ghost">关闭</text>
        </view>
      </view>
    </view>

    <view class="top-toolbar-container {{!showAudioPlayer ? 'no-audio-player' : ''}}" wx:if="{{!navigationActive}}">
      <poi-filter
        id="poiFilter"
        visible="{{showPoiFilter}}"
        default-filter="{{currentPoiFilter}}"
        bind:filterChange="onPoiFilterChange"
      />
    </view>

    <view class="popup-overlay {{showPoiPopup ? '' : 'hide'}}" wx:if="{{showPoiPopup && currentPopupData}}">
      <view class="popup-container" catchtap="noop">
        <poi-popup
          visible="{{true}}"
          popup-data="{{currentPopupData}}"
          bind:close="onClosePoiPopup"
          bind:button-action="onPoiPopupButtonAction"
        />
      </view>
    </view>

    <map-core
      longitude="{{longitude}}"
      latitude="{{latitude}}"
      scale="{{scale}}"
      show-location="{{showLocation}}"
      enable-p-o-i="{{enablePOI}}"
      markers="{{allMarkers}}"
      polyline="{{polylineData}}"
      boundary-limit="{{mapBoundaryLimit}}"
      allowed-zooms="{{allowedZooms}}"
      bind:mapReady="onMapReady"
      bind:regionChange="onRegionChange"
      bind:scaleUpdate="onScaleUpdate"
      bind:mapTap="onMapTap"
      bind:markerTap="onMarkerTap"
      bind:poiTap="onPOITap"
    />

    <view class="navigation-status-card" wx:if="{{navigationActive && navigationInfo}}">
      <view class="navigation-status-main">
        <view class="navigation-status-copy">
          <text class="navigation-status-title">{{navigationInfo.title}}</text>
          <text class="navigation-status-subtitle">{{navigationInfo.subtitle}}</text>
          <view class="navigation-status-tags">
            <text class="navigation-status-tag navigation-status-tag-{{navigationInfo.statusTone}}">{{navigationInfo.statusText}}</text>
            <text class="navigation-status-tag navigation-status-tag-muted" wx:if="{{navigationInfo.sourceTagText}}">{{navigationInfo.sourceTagText}}</text>
            <text class="navigation-status-tag navigation-status-tag-muted">{{navigationInfo.routeGapText}}</text>
            <text class="navigation-status-tag navigation-status-tag-muted" wx:if="{{navigationInfo.updatedText}}">{{navigationInfo.updatedText}}</text>
          </view>
        </view>
        <view class="navigation-status-metrics">
          <view class="navigation-status-metric">
            <view class="navigation-status-metric-row">
              <text class="navigation-status-metric-value">{{navigationInfo.distanceValue}}</text>
              <text class="navigation-status-metric-unit">{{navigationInfo.distanceUnit}}</text>
            </view>
            <text class="navigation-status-metric-caption">{{navigationInfo.distanceCaption}}</text>
          </view>
          <view class="navigation-status-metric navigation-status-metric-right">
            <view class="navigation-status-metric-row">
              <text class="navigation-status-metric-value">{{navigationInfo.durationValue}}</text>
              <text class="navigation-status-metric-unit">{{navigationInfo.durationUnit}}</text>
            </view>
            <text class="navigation-status-metric-caption">{{navigationInfo.durationCaption}}</text>
          </view>
        </view>
      </view>

      <view class="navigation-status-actions">
        <view class="navigation-status-button navigation-status-button-secondary {{navigationRecalculating && !navigationInfo.arrived ? 'navigation-status-button-disabled' : ''}}" bindtap="onNavigationSecondaryAction">
          <text class="navigation-status-button-text">{{navigationInfo.arrived ? '查看景点' : (navigationRecalculating ? '重算中...' : '重新规划')}}</text>
        </view>
        <view class="navigation-status-button" bindtap="onNavigationPrimaryAction">
          <text class="navigation-status-button-text">{{navigationInfo.arrived ? '完成导航' : '退出导航'}}</text>
        </view>
      </view>

      <view class="navigation-status-progress" wx:if="{{navigationInfo.progressText || navigationInfo.audioHintText}}">
        <view class="navigation-status-progress-head">
          <text class="navigation-status-progress-copy">{{navigationInfo.progressText}}</text>
          <text class="navigation-status-progress-copy navigation-status-progress-copy-right" wx:if="{{navigationInfo.nextGuideText}}">{{navigationInfo.nextGuideText}}</text>
        </view>
        <view class="navigation-status-progress-track">
          <view class="navigation-status-progress-fill" style="width: {{navigationInfo.progressPercent || 0}}%;"></view>
        </view>
        <text class="navigation-status-progress-hint" wx:if="{{navigationInfo.audioHintText}}">{{navigationInfo.audioHintText}}</text>
      </view>

      <view class="navigation-status-steps" wx:if="{{navigationInfo.stepItems && navigationInfo.stepItems.length}}">
        <view class="navigation-status-step" wx:for="{{navigationInfo.stepItems}}" wx:key="key">
          <view class="navigation-status-step-dot navigation-status-step-dot-{{item.state}}"></view>
          <view class="navigation-status-step-copy">
            <text class="navigation-status-step-label">{{item.label}}</text>
            <text class="navigation-status-step-value">{{item.value}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="intelligent-route-button-wrapper" wx:if="{{!navigationActive && !showPoiPopup}}">
      <gradient-button bind:tap="onIntelligentRoutePlanning">
        <image class="button-icon" src="/images/icons/intelligent-route.svg" mode="aspectFit"></image>
        <text>{{intelligentRoutePlanningText}}</text>
      </gradient-button>
    </view>

    <view
      class="audio-list-floating-button"
      wx:if="{{audioPoiList.length > 0 && !showPoiPopup}}"
      bindtap="onToggleAudioListDrawer"
    >
      <image class="audio-list-icon" src="/images/icons/voice-static.svg" mode="aspectFit"></image>
    </view>

    <view class="audio-access-test-panel" wx:if="{{!showPoiPopup}}">
      <view class="audio-access-test-copy">
        <text class="audio-access-test-title">{{audioAccessPaid ? '讲解已付费' : '讲解未付费'}}</text>
        <text class="audio-access-test-desc">{{audioAccessPaid ? '当前已解锁全部讲解内容' : '当前讲解将按VIP付费逻辑拦截'}}</text>
      </view>
      <view class="audio-access-test-actions">
        <view class="audio-access-test-button {{audioAccessPaid ? 'audio-access-test-button-paid' : ''}}" catchtap="onToggleAudioPaidForTesting">
          <text class="audio-access-test-button-text">{{audioAccessPaid ? '改为未付费' : '设为已付费'}}</text>
        </view>
      </view>
    </view>

    <intelligent-route-planner
      visible="{{showIntelligentPlanner}}"
      routes="{{plannerRoutes}}"
      selected-route-id="{{selectedIntelligentRouteId}}"
      bind:routeSelected="onIntelligentRouteSelected"
      bind:openAIChat="onOpenAIChat"
      bind:close="onCloseIntelligentPlanner"
    />

    <poi-audio-list
      visible="{{showAudioListDrawer}}"
      poi-list="{{audioPoiList}}"
      current-poi="{{currentAudioPoi}}"
      bind:close="onCloseAudioListDrawer"
      bind:select="onSelectAudioFromList"
    />
  </view>
</view>
