  height: 30vh;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 1;
  overflow: hidden;
}

/* 主渐变背景 */
.gradient-bg-main {
  width: 100%;
  height: 100%;
  position: absolute;
  left: 0;
  top: 0;
  background: 
  linear-gradient(180deg, #49BCFF 0%, #00000000 50%);
}

