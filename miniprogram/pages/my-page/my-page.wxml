<page-meta page-style="{{pageStyle}}"></page-meta>

<view class="my-page" wx:if="{{pageReady}}" style="{{navBarHeightStyle}}">
  <view class="background-layer">
    <image class="background-svg" src="/images/ai-chat-bg.svg" mode="aspectFill" />
  </view>

  <view class="page-header">
    <universal-navigation
      title="我的"
      show-back="{{true}}"
      showHomeButton="{{true}}"
      background-color="rgba(255, 255, 255, 0.12)"
      title-color="#333333"
      showUserAvatar="{{false}}"
      useCapsuleStyle="{{false}}"
      useDefaultBack="{{false}}"
      bind:back="onBackTap"
      bind:home="onHomeTap"
    />
  </view>

  <view class="content-layer">
    <view class="hero-card">
      <text class="hero-kicker">RESEARCH QUEST</text>
      <text class="hero-title">{{heroTitle}}</text>
      <text class="hero-desc">{{heroDesc}}</text>

      <view class="officer-panel">
        <view class="officer-copy">
          <text class="officer-kicker">AI 官职成长</text>
          <view class="officer-title-row">
            <text class="officer-title">{{aiOfficerTitle}}</text>
            <text class="officer-score">{{aiOfficerScoreText}}</text>
          </view>
          <text class="officer-desc">{{aiOfficerDesc}}</text>
          <text class="officer-next">{{aiOfficerNextHint}}</text>
        </view>

        <view class="officer-avatar-shell">
          <image class="officer-avatar" src="{{aiAvatarSrc}}" mode="aspectFit"></image>
          <view class="officer-badge">
            <text class="officer-badge-text">{{aiOfficerShortTitle}}</text>
          </view>
        </view>
      </view>

      <view class="officer-progress-row">
        <text class="officer-progress-label">{{aiOfficerScoreRuleText}}</text>
        <text class="officer-progress-value">{{aiOfficerStageText}}</text>
      </view>

      <view class="officer-progress-track">
        <view class="officer-progress-fill" style="width: {{aiOfficerProgressPercent}}%;"></view>
      </view>

      <view class="officer-rank-grid">
        <view
          class="officer-rank-chip {{item.reached ? 'officer-rank-chip-reached' : 'officer-rank-chip-locked'}} {{item.current ? 'officer-rank-chip-current' : ''}}"
          wx:for="{{aiOfficerRankList}}"
          wx:key="id"
        >
          <text class="officer-rank-chip-title">{{item.shortTitle}}</text>
          <text class="officer-rank-chip-threshold">{{item.thresholdText}}</text>
        </view>
      </view>

      <view class="hero-progress-row">
        <view class="hero-progress-copy">
          <text class="hero-progress-label">{{userNickname}} 的暗号收集进度</text>
          <text class="hero-progress-value">{{collectedCount}} / {{totalCount}}</text>
        </view>
        <text class="hero-progress-percent">{{progressPercentText}}</text>
      </view>

      <view class="progress-track">
        <view class="progress-fill" style="width: {{progressPercent}}%;"></view>
      </view>
    </view>

    <view class="section-head">
      <view>
        <text class="section-title">暗号图谱</text>
        <text class="section-caption">未解锁时不显示图谱；新解锁的暗号会先出现锁定提示，点击后才正式解锁展示。只有 19 枚暗号全部点亮后，才可领取研学报告。</text>
      </view>
      <text class="section-right">{{collectedCount}} / {{totalCount}}</text>
    </view>

    <view class="theme-summary-grid">
      <view
        class="theme-summary-card"
        wx:for="{{themeSummaryList}}"
        wx:key="themeName"
      >
        <text class="theme-summary-name">{{item.themeName}}</text>
        <text class="theme-summary-value">{{item.collectedCount}} / {{item.totalCount}}</text>
      </view>
    </view>

    <view class="secret-wall" id="secretWall" wx:if="{{secretList.length}}">
      <view
        class="secret-icon-card {{item.revealCollected ? 'secret-icon-card-active' : 'secret-icon-card-pending'}} {{item.pendingReveal ? 'secret-icon-card-pending-reveal' : ''}} {{item.justUnlocked ? 'secret-icon-card-unlocking' : ''}}"
        wx:for="{{secretList}}"
        wx:key="id"
        data-secret-id="{{item.id}}"
        data-pending-reveal="{{item.pendingReveal}}"
        bindtap="onSecretTap"
      >
        <view class="secret-icon-shell {{item.revealCollected ? 'secret-icon-shell-active' : 'secret-icon-shell-locked'}}">
          <block wx:if="{{item.revealCollected}}">
            <view class="secret-icon-unlock-glow" wx:if="{{item.justUnlocked}}"></view>
            <view class="secret-icon-unlock-ring" wx:if="{{item.justUnlocked}}"></view>
            <image class="secret-icon-image" src="{{item.iconDarkPath}}" mode="aspectFit"></image>
          </block>
          <block wx:else>
            <view class="secret-icon-lock {{item.pendingReveal ? 'secret-icon-lock-pending' : ''}}">
              <view class="secret-icon-lock-arch"></view>
              <view class="secret-icon-lock-body">
                <text class="secret-icon-lock-text">?</text>
              </view>
            </view>
          </block>
        </view>
        <text class="secret-icon-name">{{item.secretName}}</text>
        <text class="secret-icon-caption {{item.revealCollected ? '' : 'secret-icon-caption-locked'}}">{{item.wallCaptionText}}</text>
        <text class="secret-icon-index">{{item.secretIndexText}}</text>
      </view>
    </view>

    <view class="empty-state" wx:else>
      <text class="empty-title">暗号图标加载中</text>
      <text class="empty-desc">稍后将显示完整的 19 枚暗号图谱。</text>
    </view>

    <view class="bottom-actions">
      <view class="bottom-action bottom-action-primary" bindtap="onOpenCollectionPage">
        <text class="bottom-action-text bottom-action-text-primary">{{reportUnlocked ? '回看收集点' : '去收集暗号'}}</text>
      </view>
      <view class="bottom-action bottom-action-secondary" bindtap="onOpenMapPage">
        <text class="bottom-action-text bottom-action-text-secondary">打开地图</text>
      </view>
    </view>
  </view>
</view>
