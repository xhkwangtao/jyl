  display: flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  border: 3rpx solid #ffffff;
  border-radius: 50%;
  background: #667eea;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 500;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.simple-username {
  display: flex;
  justify-content: center;
  flex-direction: column;
  max-width: 160rpx;
  margin-bottom: 2rpx;
  color: #000000;
  font-size: 20rpx;
  font-weight: 500;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.simple-score-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.simple-score-number {
  color: #999999;
  font-size: 24rpx;
  font-weight: 500;
  line-height: 20rpx;
}

.simple-score-label {
  color: #999999;
  font-size: 24rpx;
  font-weight: 400;
  line-height: 20rpx;
}

.simple-podium-item.self-item .simple-avatar {
  border: 6rpx solid #00ff88;
  box-shadow: 0 0 16rpx rgba(0, 255, 136, 0.3);
}

.simple-podium-item.self-item .simple-username {
  color: #00ff88;
  font-weight: 600;
}

.simple-podium-item.self-item .simple-rank-badge {
  background: #00ff88;
}

.ranking-items {
  background: #ffffff;
}

.ranking-item {
  display: flex;
  align-items: center;
  padding: 15rpx 32rpx;
  border-bottom: 2rpx solid #f8f9fa;
  transition: background-color 0.2s ease;
}

.ranking-item:last-child {
  border-bottom: none;
}

.ranking-item:active {
  background-color: #f8f9fa;
}

.ranking-item.self-item {
  background: linear-gradient(90deg, rgba(102, 126, 234, 0.05) 0%, rgba(118, 75, 162, 0.05) 100%);
  border-left: 6rpx solid #667eea;
}

.rank-number-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  margin-right: 24rpx;
  border-radius: 50%;
  background: transparent;
}

.rank-number {
  color: rgb(111, 111, 111);
  font-size: 30rpx;
  font-weight: 700;
}

.user-avatar {
  width: 72rpx;
  height: 72rpx;
  margin-right: 24rpx;
  border: 3rpx solid #f8f9fa;
  border-radius: 50%;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.user-nickname {
  color: #333333;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1.2;
}

.user-title {
  color: #666666;
  font-size: 22rpx;
  line-height: 1.2;
}

.score-display {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 2rpx;
}

.score-number {
  color: #667eea;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.2;
}

.ranking-item .score-label,
.score-label-small {
  color: #999999;
  font-size: 20rpx;
  line-height: 1.2;
}

.my-rank-card-container-fixed {
  position: fixed !important;
  bottom: 0 !important;
  left: 50% !important;
  z-index: 9998 !important;
  width: 710rpx;
  height: 300rpx;
  padding-bottom: calc(40rpx + var(--page-safe-bottom, 0px));
  overflow: visible !important;
  transform: translateX(-50%) !important;
  transition: none !important;
  will-change: auto !important;
  isolation: isolate;
  pointer-events: auto;
  animation: slideUpFromBottom 0.6s ease-out;
}

.my-rank-card {
