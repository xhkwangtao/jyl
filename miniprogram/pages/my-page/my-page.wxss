/* pages/my-page/my-page.wxss */

@keyframes slideUpIn {
  0% {
    opacity: 0.8;
    transform: translateY(60rpx);
  }

  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeInScale {
  0% {
    opacity: 0;
    transform: scale(0.9);
  }

  100% {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes slideUpFromBottom {
  0% {
    transform: translateY(100%);
    opacity: 0;
  }

  100% {
    transform: translateY(0);
    opacity: 1;
  }
}

@keyframes fadeInUp {
  0% {
    transform: translateY(40rpx);
    opacity: 0;
  }

  100% {
    transform: translateY(0);
    opacity: 1;
  }
}

@keyframes slideUp {
  0% {
    transform: translateY(100rpx);
    opacity: 0;
  }

  100% {
    transform: translateY(0);
    opacity: 1;
  }
}

:root {
  --spacing-xs: 1vh;
  --spacing-sm: 2vh;
  --spacing-md: 3vh;
  --spacing-lg: 5vh;
  --spacing-xl: 8vh;
  --page-padding-top: 15vh;
  --page-padding-bottom: 5vh;
  --page-padding-side: 20px;
}

.my-page {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden !important;
  transform: none;
  will-change: auto;
}

.background-layer {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
  overflow: hidden;
}

.background-svg {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center center;
  image-rendering: auto;
  image-rendering: -webkit-optimize-contrast;
  user-select: none;
  pointer-events: none;
}

.page-header {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  z-index: 1000;
  background: transparent;
}

.content-layer {
  position: fixed;
  top: var(--nav-bar-height, 84px);
  left: 0;
  right: 0;
  height: calc(100vh - var(--nav-bar-height, 84px));
  z-index: 1;
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(0.5px);
  overflow: hidden !important;
  transform: none;
  will-change: auto;
}

.my-page.compact-mode .content-layer {
  top: calc(var(--nav-bar-height, 84px) + 80rpx);
  height: calc(100vh - var(--nav-bar-height, 84px) - 80rpx);
}

.main-content {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  gap: 0;
  height: 100vh;
  padding: var(--spacing-md) var(--page-padding-side) calc(40rpx + var(--page-safe-bottom, 0px));
  overflow: hidden !important;
  box-sizing: border-box;
  transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.main-content[data-tab="badge"] {
  padding-bottom: calc(160rpx + var(--page-safe-bottom, 0px));
}

.main-content[data-tab="ranking"] {
  padding-bottom: calc(340rpx + var(--page-safe-bottom, 0px));
}

.my-page.compact-mode .main-content {
  gap: 0;
  padding-top: var(--spacing-sm);
}

.main-content tab-switch,
.main-content badge-grid {
  width: 100%;
  display: block;
  box-sizing: border-box;
}

.tab-content-container {
  position: relative;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-sm);
  margin: 0 !important;
  box-sizing: border-box !important;
  transform: translateZ(0);
  transform-origin: top center;
  will-change: transform;
  backface-visibility: hidden;
  z-index: 10;
  touch-action: pan-y;
  -webkit-user-select: none;
  user-select: none;
  border-radius: 24rpx;
  transition: box-shadow 0.2s ease;
}

.tab-content-container.collapsed-mode {
  height: calc(100vh - var(--nav-bar-height, 84px) - 40px);
  max-height: calc(100vh - var(--nav-bar-height, 84px) - 40px);
  animation-name: slideUpIn;
  animation-duration: 0.8s;
  animation-timing-function: cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.tab-content-container.expanded-mode {
  min-height: auto;
  flex: none;
}

.tab-content-container::before {
  content: '';
  position: absolute;
  top: 16rpx;
  left: 50%;
  width: 80rpx;
  height: 8rpx;
  transform: translateX(-50%);
  border-radius: 4rpx;
  z-index: 1;
  transition: all 0.3s ease;
}

.tab-content-container:active::before {
  top: 12rpx;
  width: 120rpx;
  height: 10rpx;
}

.tab-content-container.dragging {
  transition: none !important;
}

.tab-content-container.spring-animation {
  transition: transform 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275) !important;
}

.tab-container,
.content-container,
.badge-container,
.ranking-container {
  width: 100%;
  box-sizing: border-box;
}

.tab-container,
.content-container,
.badge-container {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.content-container {
  flex: 1;
}

.badge-container {
  position: relative;
  z-index: 1;
  isolation: isolate;
  animation: fadeInUp 0.35s ease-out;
}

.tab-content-container.collapsed-mode .tab-container {
  position: relative;
  z-index: 10;
  width: 100%;
  padding: 10rpx 0;
  border-radius: 20rpx;
  backdrop-filter: blur(10px);
}

.tab-content-container.collapsed-mode .content-container {
  position: relative;
  flex: 1;
  max-height: calc(100vh - 180rpx);
  overflow: hidden;
}

.tab-content-container.collapsed-mode .badge-container {
  flex: 1;
  max-height: calc(100vh - var(--page-padding-top) - 120rpx);
  overflow: hidden;
}

.tab-content-container.expanded-mode .badge-container {
  max-height: 80vh;
  overflow: hidden !important;
}

.tab-content-container.collapsed-mode badge-grid .badge-grid-container,
.tab-content-container.expanded-mode badge-grid .badge-grid-container {
  max-height: none !important;
  height: auto !important;
  overflow: visible !important;
  clip-path: none !important;
  contain: none !important;
}

.tab-content-container.expanded-mode badge-grid .badge-grid-container {
  overflow: hidden !important;
  clip-path: inset(0) !important;
}

.ranking-container {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  padding: 20rpx 32rpx;
  padding-bottom: calc(360rpx + var(--page-safe-bottom, 0px));
  overflow: visible;
  animation: fadeInUp 0.35s ease-out;
}

.top-ranking-list {
  position: relative;
  z-index: 9999;
  margin-top: 0;
  margin-bottom: 32rpx;
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.list-header {
  padding: 24rpx 32rpx;
  background: linear-gradient(90deg, #f8f9fa 0%, #e9ecef 100%);
  border-bottom: 2rpx solid #f1f3f4;
}

.list-title {
  color: #333333;
  font-size: 30rpx;
  font-weight: 600;
}

.top-three-simple {
  display: flex;
  justify-content: center;
  align-items: flex-end;
  gap: 4rpx;
  background: #ffffff;
}

.simple-podium-item {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  max-width: 180rpx;
}

.simple-podium-item.first-place {
  transform: translateY(-5vh);
}

.avatar-container {
  position: relative;
  margin-bottom: 16rpx;
}

.simple-avatar {
  display: block;
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
}

.simple-rank-badge {
  position: absolute;
  top: -8rpx;
