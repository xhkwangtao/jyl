.my-page {
  position: relative;
  min-height: 100vh;
  overflow-x: hidden;
}

.background-layer {
  position: fixed;
  inset: 0;
  z-index: 0;
}

.background-svg {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  pointer-events: none;
}

.page-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 5;
}

.content-layer {
  position: relative;
  z-index: 2;
  padding: calc(212rpx + constant(safe-area-inset-top)) 32rpx calc(96rpx + constant(safe-area-inset-bottom));
  padding: calc(212rpx + env(safe-area-inset-top)) 32rpx calc(96rpx + env(safe-area-inset-bottom));
}

.hero-card,
.report-card,
.rules-card,
.secret-card,
.empty-state {
  position: relative;
  overflow: hidden;
  border-radius: 32rpx;
  border: 1px solid rgba(36, 72, 92, 0.1);
  box-shadow: 0 18rpx 44rpx rgba(31, 58, 74, 0.1);
}

.hero-card::before,
.report-card::before,
.rules-card::before,
.secret-card::before,
.empty-state::before {
  content: '';
  position: absolute;
  inset: 0;
  pointer-events: none;
  background:
    radial-gradient(circle at top right, rgba(45, 123, 122, 0.1), transparent 30%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.32), transparent 38%);
}

.hero-card {
  padding: 30rpx;
  background:
    radial-gradient(circle at top right, rgba(47, 128, 125, 0.08), transparent 34%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.68) 0%, rgba(255, 250, 243, 0.94) 100%);
}

.hero-kicker,
.hero-title,
.hero-desc,
.hero-progress-row,
.progress-track,
.stats-grid,
.report-chip,
.report-title,
.report-desc,
.report-actions,
.rule-list,
.section-head,
.secret-card,
.empty-state,
.bottom-actions {
  position: relative;
  z-index: 1;
}

.hero-kicker {
  display: block;
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: #6f8d93;
}

.hero-title {
  display: block;
  margin-top: 12rpx;
  font-size: 42rpx;
  line-height: 1.24;
  font-weight: 700;
  color: #1f2d35;
}

.hero-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #5c6d74;
}

.hero-progress-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 28rpx;
}

.hero-progress-label {
  display: block;
  font-size: 22rpx;
  color: #7a8d92;
}

.hero-progress-value {
  display: block;
  margin-top: 6rpx;
  font-size: 40rpx;
  line-height: 1;
  font-weight: 700;
  color: #1f2d35;
}

.hero-progress-percent {
  flex-shrink: 0;
  font-size: 24rpx;
  font-weight: 700;
  color: #1f6a67;
}

.progress-track {
  height: 16rpx;
  margin-top: 20rpx;
  border-radius: 999rpx;
  background: rgba(45, 123, 122, 0.12);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #2cedb8 0%, #2f807d 100%);
}

.stats-grid {
  display: flex;
  gap: 14rpx;
  margin-top: 24rpx;
}

.stat-card {
  flex: 1;
  min-width: 0;
  padding: 20rpx 18rpx 22rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fdfcf9 0%, #eef5f3 100%);
  border: 1px solid rgba(45, 123, 122, 0.08);
}

.stat-card-checked {
  background: linear-gradient(180deg, rgba(44, 237, 184, 0.2) 0%, rgba(228, 255, 248, 0.95) 100%);
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #7a8d92;
}

.stat-value {
  display: block;
  margin-top: 10rpx;
  font-size: 32rpx;
  line-height: 1;
  font-weight: 700;
  color: #1f2d35;
}

.report-card,
.rules-card {
  margin-top: 24rpx;
  padding: 28rpx;
  background: rgba(255, 251, 246, 0.95);
}

.report-card-ready {
  background:
    radial-gradient(circle at top right, rgba(44, 237, 184, 0.12), transparent 32%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.74) 0%, rgba(239, 255, 249, 0.96) 100%);
}

.report-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
}

.report-chip-ready {
  background: rgba(44, 237, 184, 0.2);
}

.report-chip-pending {
  background: rgba(36, 95, 109, 0.08);
}

.report-chip-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #1f6a67;
}

.report-title {
  display: block;
  margin-top: 18rpx;
  font-size: 34rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #1f2d35;
}

.report-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #5c6d74;
}

.report-actions,
.bottom-actions {
  display: flex;
  gap: 14rpx;
}

.report-actions {
  margin-top: 22rpx;
}

.report-action,
.bottom-action {
  flex: 1;
  min-height: 82rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.report-action-primary,
.bottom-action-primary {
  background: linear-gradient(180deg, #2f807d 0%, #245f6d 100%);
  box-shadow: 0 14rpx 26rpx rgba(36, 95, 109, 0.14);
}

.report-action-secondary,
.bottom-action-secondary {
  background: rgba(255, 255, 255, 0.92);
  border: 1px solid rgba(36, 95, 109, 0.12);
}

.report-action-text,
.bottom-action-text {
  font-size: 24rpx;
  font-weight: 700;
}

.report-action-text-primary,
.bottom-action-text-primary {
  color: #ffffff;
}

.report-action-text-secondary,
.bottom-action-text-secondary {
  color: #245f6d;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 28rpx;
  padding: 0 6rpx;
}

.section-head-static {
  margin-top: 0;
  padding: 0;
}

.section-title {
  display: block;
  font-size: 32rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #1f2d35;
}

.section-caption,
.section-right {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #6f8d93;
}

.section-right {
  margin-top: 0;
  flex-shrink: 0;
}

.rule-list,
.secret-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.rule-list {
  margin-top: 24rpx;
}

.rule-item {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.rule-index-shell {
  width: 70rpx;
  height: 70rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #2f807d 0%, #245f6d 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.rule-index {
  font-size: 24rpx;
  font-weight: 700;
  color: #ffffff;
}

.rule-copy {
  flex: 1;
  min-width: 0;
}

.rule-title {
  display: block;
  font-size: 28rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #1f2d35;
}

.rule-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: #5c6d74;
}

.secret-list {
  margin-top: 20rpx;
}

.secret-card {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 24rpx;
  background: rgba(255, 251, 246, 0.95);
}

.secret-card-collected {
  border-color: rgba(44, 237, 184, 0.22);
}

.secret-code-shell {
  width: 92rpx;
  min-height: 110rpx;
  border-radius: 26rpx;
  background: linear-gradient(180deg, #fbf6ef 0%, #f4ecdf 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.secret-card-collected .secret-code-shell {
  background: linear-gradient(180deg, #2f807d 0%, #245f6d 100%);
  box-shadow: 0 14rpx 26rpx rgba(36, 95, 109, 0.16);
}

.secret-code {
  font-size: 32rpx;
  font-weight: 700;
  color: #c27d42;
}

.secret-card-collected .secret-code {
  color: #ffffff;
}

.secret-code-label {
  font-size: 18rpx;
  color: #8d6d51;
}

.secret-card-collected .secret-code-label {
  color: rgba(255, 255, 255, 0.8);
}

.secret-copy {
  flex: 1;
  min-width: 0;
}

.secret-meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.secret-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.secret-tag-gold {
  background: rgba(196, 133, 75, 0.14);
  color: #a96835;
}

.secret-tag-teal {
  background: rgba(45, 123, 122, 0.12);
  color: #21646f;
}

.secret-tag-stone {
  background: rgba(96, 106, 120, 0.12);
  color: #55606b;
}

.secret-status-chip {
  flex-shrink: 0;
  min-height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.secret-status-chip-collected {
  background: rgba(44, 237, 184, 0.18);
}

.secret-status-chip-pending {
  background: rgba(16, 24, 40, 0.06);
}

.secret-status-text {
  font-size: 20rpx;
  font-weight: 700;
  color: #1f2d35;
}

.secret-title {
  display: block;
  margin-top: 12rpx;
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #1f2d35;
}

.secret-hint {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #245f6d;
}

.secret-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #5c6d74;
}

.secret-time {
  display: block;
  margin-top: 14rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #70828a;
}

.secret-card-collected .secret-time {
  color: #19886a;
}

.empty-state {
  margin-top: 20rpx;
  padding: 40rpx 32rpx;
  text-align: center;
  background: rgba(255, 251, 246, 0.95);
}

.empty-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2d35;
}

.empty-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #70828a;
}

.bottom-actions {
  margin-top: 28rpx;
}

@media (max-width: 375px) {
  .content-layer {
    padding-left: 24rpx;
    padding-right: 24rpx;
  }

  .hero-title {
    font-size: 38rpx;
  }

  .stats-grid,
  .report-actions,
  .bottom-actions {
    flex-wrap: wrap;
  }

  .report-action,
  .bottom-action {
    min-width: 100%;
  }
}
