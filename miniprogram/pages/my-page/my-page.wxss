  top: 186rpx;
  z-index: 5;
  width: 14rpx;
  height: 14rpx;
  background: #eaeaea;
  transform: rotate(-90deg);
}

.quick-links-section.bottom-fixed {
  position: fixed !important;
  bottom: 0 !important;
  left: 0 !important;
  right: 0 !important;
  z-index: 9999 !important;
  display: flex;
  justify-content: center;
  gap: 24rpx;
  width: 100% !important;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + var(--page-safe-bottom, 0px));
  background: linear-gradient(180deg, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0.98) 20%, rgba(255, 255, 255, 1) 100%);
  backdrop-filter: blur(20rpx);
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.08);
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
  transform: none !important;
  transition: none !important;
  animation: none !important;
  will-change: auto !important;
  isolation: isolate;
}

.action-button {
  flex: 1;
  max-width: 320rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border: none;
  outline: none;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  backdrop-filter: blur(8rpx);
  transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.action-button::after,
.qrcode-save-btn::after {
  border: none;
}

.action-button.primary {
  background: linear-gradient(135deg, #4aedc4 0%, #6ef3d1 100%);
  color: #0a5f4b;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  box-shadow: 0 8rpx 24rpx rgba(76, 237, 196, 0.25);
}

.action-button.primary:active {
  transform: translateY(2rpx) scale(0.98);
  opacity: 0.95;
  box-shadow: 0 6rpx 16rpx rgba(76, 237, 196, 0.2);
}

.action-button.secondary {
  background: linear-gradient(135deg, #f0fffe 0%, #e8fff9 100%);
  color: #0a5f4b;
  border: 1.5rpx solid rgba(76, 237, 196, 0.3);
  box-shadow: 0 6rpx 20rpx rgba(76, 237, 196, 0.15);
}

.action-button.secondary:active {
  transform: translateY(2rpx) scale(0.98);
  background: linear-gradient(135deg, #d8fff0 0%, #e8fff6 100%);
  box-shadow: 0 4rpx 12rpx rgba(76, 237, 196, 0.08);
  border-color: rgba(76, 237, 196, 0.4);
}

.button-icon {
  display: inline-block;
  margin-right: 8rpx;
  font-size: 32rpx;
}

.qrcode-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qrcode-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(10rpx);
}

.qrcode-container {
  position: relative;
  z-index: 1;
  width: 100%;
  padding: 0 60rpx;
  box-sizing: border-box;
}

.qrcode-card {
  position: relative;
  padding: 50rpx 40rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  animation: slideUp 0.3s ease-out;
}

.qrcode-close {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.05);
  transition: all 0.2s ease;
}

.qrcode-close:active {
  transform: scale(0.9);
  background: rgba(0, 0, 0, 0.1);
}

.qrcode-close-icon {
  color: #666666;
  font-size: 36rpx;
  line-height: 1;
}

.qrcode-title {
  margin-bottom: 40rpx;
  color: #333333;
  font-size: 36rpx;
  font-weight: 600;
  text-align: center;
}

.qrcode-image {
  display: block;
  width: 500rpx;
  height: 500rpx;
  margin: 0 auto;
  border: 2rpx solid rgba(0, 0, 0, 0.05);
  border-radius: 16rpx;
  transition: all 0.2s ease;
}

.qrcode-image:active {
  transform: scale(0.98);
}

.qrcode-tips {
  margin-top: 40rpx;
  text-align: center;
}

.qrcode-tip-text {
  display: block;
  color: #999999;
  font-size: 26rpx;
  line-height: 1.8;
}

.qrcode-save-btn {
  width: 100%;
  height: 88rpx;
  margin-top: 40rpx;
  border: none;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #2cedb8 0%, #00ff88 100%);
  color: #000000;
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 12rpx 32rpx rgba(44, 237, 184, 0.3);
  transition: all 0.2s ease;
}

.qrcode-save-btn:active {
  transform: scale(0.98);
  box-shadow: 0 8rpx 20rpx rgba(44, 237, 184, 0.25);
}

@media (max-width: 375px) {
  .main-content {
    padding: var(--spacing-xs) 15px;
  }

  .my-page.compact-mode .content-layer {
    top: calc(var(--nav-bar-height, 84px) + 60rpx);
    height: calc(100vh - var(--nav-bar-height, 84px) - 60rpx);
  }

  .quick-links-section.bottom-fixed {
    gap: 20rpx;
    padding: 12rpx 20rpx;
    padding-bottom: calc(12rpx + var(--page-safe-bottom, 0px));
  }

  .action-button {
    height: 80rpx;
    gap: 10rpx;
    font-size: 26rpx;
  }

  .button-icon {
    font-size: 28rpx;
  }

  .qrcode-container {
    padding: 0 40rpx;
  }

  .qrcode-image {
    width: 420rpx;
    height: 420rpx;
  }
}

@media (max-width: 320px) {
  .quick-links-section.bottom-fixed {
    flex-direction: row;
    gap: 12rpx;
    padding: 10rpx 16rpx;
    padding-bottom: calc(10rpx + var(--page-safe-bottom, 0px));
  }

  .action-button {
    max-width: none;
    height: 76rpx;
    gap: 8rpx;
    font-size: 24rpx;
  }

  .button-icon {
    font-size: 26rpx;
  }
}

@media (min-width: 768px) {
  .quick-links-section.bottom-fixed {
    left: 50% !important;
    right: auto !important;
    max-width: 600rpx;
    margin: 0 auto;
    padding: 20rpx 48rpx;
    padding-bottom: calc(20rpx + var(--page-safe-bottom, 0px));
    gap: 32rpx;
    border-radius: 24rpx 24rpx 0 0;
    transform: translateX(-50%) !important;
  }

  .action-button {
    height: 96rpx;
    gap: 16rpx;
    font-size: 30rpx;
    border-radius: 48rpx;
  }

  .button-icon {
    font-size: 36rpx;
  }
}
